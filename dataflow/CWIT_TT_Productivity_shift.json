{
	"name": "CWIT_TT_Productivity_shift",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "linkedService2",
						"type": "LinkedServiceReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "linkedService2",
						"type": "LinkedServiceReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "filter1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "window1"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "aggregate1"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "derivedColumn6"
				},
				{
					"name": "select1"
				},
				{
					"name": "join1"
				},
				{
					"name": "select2"
				},
				{
					"name": "alterRow1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          mve_gkey as integer,",
				"          Unit_Nbr as string,",
				"          Facility_Id as string,",
				"          Complex_Id as string,",
				"          Yard_Id as string,",
				"          Carrier_Visit_Key as integer,",
				"          Event_Type_Id as string,",
				"          Move_Kind as string,",
				"          From_Location as string,",
				"          To_Location as string,",
				"          From_Position_Name as string,",
				"          To_Position_Name as string,",
				"          Carry_CHE_Operator_Id as short,",
				"          Fetch_CHE_Operator_Id as string,",
				"          Put_CHE_Operator_Id as string,",
				"          Fetch_CHE_Id as long,",
				"          Fetch_CHE_Kind as string,",
				"          Carry_CHE_Id as long,",
				"          Carry_CHE_Kind as string,",
				"          Put_CHE_Id as long,",
				"          Put_CHE_Kind as string,",
				"          QC_CHE_Id as long,",
				"          QC_CHE_Kind as string,",
				"          t_carry_complete as timestamp,",
				"          t_put as timestamp,",
				"          t_fetch as timestamp,",
				"          t_dispatch as timestamp,",
				"          t_discharge as timestamp,",
				"          t_carry_dispatch as timestamp,",
				"          t_carry_fetch_ready as timestamp,",
				"          t_carry_put_ready as timestamp,",
				"          dist_carry as integer,",
				"          dist_start as short,",
				"          Twin_Fetch as string,",
				"          Twin_Carry as string,",
				"          Twin_Put as string,",
				"          Category_Id as string,",
				"          Freight_Kind_Id as string,",
				"          to_pos_gkey as integer,",
				"          fm_pos_gkey as integer,",
				"          Restow_Reason as string,",
				"          Container_Line_Id as string,",
				"          Container_Line_Role as string,",
				"          pow as string,",
				"          ufv_gkey as integer,",
				"          Berth_Id as string,",
				"          Goods_And_Ctr_Wt_Kg as double,",
				"          active_ufv as integer,",
				"          Requires_Power_Flag as string,",
				"          OOG_Flag as string,",
				"          Shipper_Id as string,",
				"          Consignee_Id as string,",
				"          Commodity_Id as string,",
				"          ATA as timestamp,",
				"          ATD as timestamp,",
				"          Rehandles as string,",
				"          Year as integer,",
				"          Month as integer,",
				"          Week as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delta',",
				"     fileSystem: 'cwit',",
				"     folderPath: 'silver/moves') ~> source1",
				"source1 filter(equals(Carry_CHE_Kind, 'ITV')) ~> filter1",
				"filter1 derive(CompletionTime = iif(isNull(t_carry_complete), t_put, t_carry_complete),",
				"          ShiftDate = iif(",
				"        toInteger(split(toString(",
				"            iif(isNull(t_carry_complete), t_put, t_carry_complete),",
				"            'HH:mm:ss'), ':')[1]) < 8,",
				"        addDays(toDate(toString(",
				"            iif(isNull(t_carry_complete), t_put, t_carry_complete),",
				"            'yyyy-MM-dd')), -1),",
				"        toDate(toString(",
				"            iif(isNull(t_carry_complete), t_put, t_carry_complete),",
				"            'yyyy-MM-dd'))",
				"    ),",
				"          WorkingShift = iif(",
				"        toInteger(split(toString(",
				"            iif(isNull(t_carry_complete), t_put, t_carry_complete),",
				"            'HH:mm:ss'), ':')[1]) >= 8",
				"        && toInteger(split(toString(",
				"            iif(isNull(t_carry_complete), t_put, t_carry_complete),",
				"            'HH:mm:ss'), ':')[1]) < 20,",
				"        'Shift 1', 'Shift 2'",
				"    )) ~> derivedColumn1",
				"derivedColumn1 derive(ShiftStartTime = toTimestamp(         toString(ShiftDate, 'yyyy-MM-dd') + ' ' +         iif(WorkingShift == 'Shift 1', '08:00:00', '20:00:00'),         'yyyy-MM-dd HH:mm:ss'     ),",
				"          ShiftEndTime = toTimestamp(         toString(             iif(WorkingShift == 'Shift 1', ShiftDate, addDays(ShiftDate, 1)),             'yyyy-MM-dd'         ) + ' ' +         iif(WorkingShift == 'Shift 1', '19:59:59', '07:59:59'),         'yyyy-MM-dd HH:mm:ss'     )) ~> derivedColumn2",
				"derivedColumn2 window(over(Carry_CHE_Id,",
				"          ShiftDate,",
				"          WorkingShift),",
				"     asc(CompletionTime, true),",
				"     asc(mve_gkey, true),",
				"     NextMoveTime = lead(CompletionTime, 1),",
				"          PrevMoveTime = lag(CompletionTime, 1),",
				"          MoveRank = rowNumber()) ~> window1",
				"window1 derive(GapToNextMove_ms = iif(",
				"        isNull(NextMoveTime),",
				"        toLong(0),",
				"        iif(toLong(NextMoveTime - CompletionTime) < 0,",
				"            toLong(0),",
				"            toLong(NextMoveTime - CompletionTime)",
				"        )",
				"    ),",
				"          GapToPrevMove_ms = iif(",
				"        isNull(PrevMoveTime),",
				"        toLong(0),",
				"        iif(toLong(CompletionTime - PrevMoveTime) < 0,",
				"            toLong(0),",
				"            toLong(CompletionTime - PrevMoveTime)",
				"        )",
				"    ),",
				"          TimeFromShiftStart = toLong(CompletionTime - ShiftStartTime),",
				"          TimeToShiftEnd = toLong(ShiftEndTime - CompletionTime)) ~> derivedColumn3",
				"derivedColumn3 derive(IsIdleAfter = GapToNextMove_ms > 10800000) ~> derivedColumn4",
				"derivedColumn4 aggregate(groupBy(Carry_CHE_Id,",
				"          ShiftDate,",
				"          WorkingShift),",
				"     First_Lift_Raw = min(CompletionTime),",
				"          Last_Lift_Raw = max(CompletionTime),",
				"          Move_Count = countDistinct(mve_gkey),",
				"          Move_Count_AdjTwin = sum(iif(in(['TRUE','YES'], upper(Twin_Carry)), 0.5, 1.0))\r",
				",",
				"          TotalIdleTime = sumIf(GapToNextMove_ms > 10800000, GapToNextMove_ms),",
				"          ShiftStartTime = first(ShiftStartTime),",
				"          ShiftEndTime = first(ShiftEndTime)) ~> aggregate1",
				"aggregate1 derive(First_Lift = iif(",
				"               toLong(First_Lift_Raw - ShiftStartTime) > 10800000,",
				"               First_Lift_Raw,",
				"               ShiftStartTime",
				"          ),",
				"          Last_Lift = ShiftEndTime) ~> derivedColumn5",
				"derivedColumn5 derive(WorkTime = iif(",
				"               Move_Count == 1,",
				"               iif(",
				"                    toLong(First_Lift_Raw - ShiftStartTime) <= toLong(ShiftEndTime - Last_Lift_Raw)",
				"                         && toLong(First_Lift_Raw - ShiftStartTime) > 0,",
				"                    toLong(First_Lift_Raw - ShiftStartTime),",
				"                    iif(",
				"                         toLong(ShiftEndTime - Last_Lift_Raw) > 0,",
				"                         toLong(ShiftEndTime - Last_Lift_Raw),",
				"                         toLong(3600000)",
				"                    )",
				"               ),",
				"               iif(",
				"                    toLong(Last_Lift - First_Lift) - iifNull(TotalIdleTime, toLong(0)) < 0,",
				"                    toLong(0),",
				"                    toLong(Last_Lift - First_Lift) - iifNull(TotalIdleTime, toLong(0))",
				"               )",
				"          ),",
				"          Year = year(ShiftDate),",
				"          Month = month(ShiftDate)) ~> derivedColumn6",
				"derivedColumn6 select(mapColumn(",
				"          Carry_CHE_Id,",
				"          ShiftDate,",
				"          WorkingShift,",
				"          First_Lift_Raw,",
				"          Last_Lift_Raw,",
				"          First_Lift,",
				"          Last_Lift,",
				"          Move_Count,",
				"          Move_Count_AdjTwin,",
				"          TotalIdleTime,",
				"          WorkTime,",
				"          Year,",
				"          Month",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"derivedColumn4, select1 join(source1@Carry_CHE_Id == select1@Carry_CHE_Id",
				"     && derivedColumn1@ShiftDate == select1@ShiftDate",
				"     && derivedColumn1@WorkingShift == select1@WorkingShift,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 select(mapColumn(",
				"          mve_gkey,",
				"          Unit_Nbr,",
				"          From_Position_Name,",
				"          To_Position_Name,",
				"          pow,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          Carry_CHE_Id = source1@Carry_CHE_Id,",
				"          Carry_CHE_Kind,",
				"          Move_Kind,",
				"          CompletionTime,",
				"          ShiftDate = derivedColumn1@ShiftDate,",
				"          WorkingShift = derivedColumn1@WorkingShift,",
				"          ShiftStartTime,",
				"          ShiftEndTime,",
				"          MoveRank,",
				"          GapToNextMove_ms,",
				"          GapToPrevMove_ms,",
				"          TimeFromShiftStart,",
				"          TimeToShiftEnd,",
				"          IsIdleAfter,",
				"          Twin_Carry,",
				"          pow,",
				"          dist_carry,",
				"          dist_start,",
				"          First_Lift_Raw,",
				"          Last_Lift_Raw,",
				"          First_Lift,",
				"          Last_Lift,",
				"          Move_Count,",
				"          Move_Count_AdjTwin,",
				"          TotalIdleTime,",
				"          WorkTime,",
				"          Year,",
				"          Month",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select2 alterRow(upsertIf(true())) ~> alterRow1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: 'cwit',",
				"     folderPath: 'gold/tt_productivity_shift',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: false,",
				"     updateable: false,",
				"     upsertable: true,",
				"     keys:['mve_gkey'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}