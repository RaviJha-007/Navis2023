{
	"name": "RSGT_jobstep_Missed",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "linkedService1",
						"type": "LinkedServiceReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "linkedService1",
						"type": "LinkedServiceReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "filter1"
				},
				{
					"name": "window1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "AlterRow1"
				},
				{
					"name": "select1"
				},
				{
					"name": "select2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ecEventGkey as long,",
				"          yardgkey as short,",
				"          yardid as string,",
				"          fcyid as string,",
				"          chekind as string,",
				"          che_name as string,",
				"          che_id as short,",
				"          timestamp as string,",
				"          eventtype as short,",
				"          eventsubtype as short,",
				"          eventtypedescription as string,",
				"          fromcheidname as string,",
				"          tocheidname as string,",
				"          unit as string,",
				"          pow as string,",
				"          pool as string,",
				"          workqueue as string,",
				"          traveldistance as short,",
				"          movekind as string,",
				"          istwin as boolean,",
				"          startdistance as short,",
				"          workassignment as long,",
				"          unitref as string,",
				"          tran_id as string,",
				"          loctype as string,",
				"          locid as string,",
				"          locslot as string,",
				"          opsposid as string,",
				"          unladenloctype as string,",
				"          unladenlocid as string,",
				"          unladenlocslot as string,",
				"          ladenloctype as string,",
				"          ladenlocid as string,",
				"          laden_locslot as string,",
				"          lastestmovetime as string,",
				"          operator_name as string,",
				"          EcEventTime as timestamp,",
				"          Year as integer,",
				"          Month as integer,",
				"          Week as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delta',",
				"     fileSystem: 'rsgt',",
				"     folderPath: 'silver/ecevents') ~> source1",
				"select2 filter(not(isNull(ecEventGkey)) && cheKind==\"ITV\" && (eventTypeDescription==\"AYCO\" || eventTypeDescription==\"TVDR\" || eventTypeDescription==\"AVDR\" || eventTypeDescription==\"AVCO\" || eventTypeDescription==\"TYDR\" || eventTypeDescription==\"AYDR\" ) && (moveKind==\"DSCH\"||moveKind==\"LOAD\")) ~> filter1",
				"filter1 window(over(cheID),",
				"     asc(EcEventTime, true),",
				"     asc(ecEventGkey, true),",
				"     eventTypeDescription_nxt = lead(eventTypeDescription),",
				"          eventTypeDescription_lag = lag(eventTypeDescription)) ~> window1",
				"window1 derive(jobStep = iif(eventTypeDescription == 'TVDR',\r",
				"    iif(eventTypeDescription_nxt == 'AVDR' && eventTypeDescription_lag == 'AYCO', 1, 0),\r",
				"    iif(eventTypeDescription == 'TYDR',\r",
				"        iif(eventTypeDescription_nxt == 'AYDR' && eventTypeDescription_lag == 'AVCO', 1, 0),\r",
				"        toInteger(null())\r",
				"    )\r",
				"),",
				"          Types = case(\r",
				"    eventTypeDescription == 'TVDR', \r",
				"        iif((eventTypeDescription_nxt != 'AVDR' || isNull(eventTypeDescription_nxt)) && (eventTypeDescription_lag != 'AYCO' || isNull(eventTypeDescription_lag)), 'Miss at Vessel and Row',\r",
				"        iif(eventTypeDescription_nxt != 'AVDR' || isNull(eventTypeDescription_nxt), 'Load-Miss Arrive at Vessel',\r",
				"        iif(eventTypeDescription_lag != 'AYCO' || isNull(eventTypeDescription_lag), 'Load-Miss Arrive at Row', 'No Violation'))),\r",
				"    \r",
				"    eventTypeDescription == 'TYDR', \r",
				"        iif((eventTypeDescription_nxt != 'AYDR' || isNull(eventTypeDescription_nxt)) && (eventTypeDescription_lag != 'AVCO' || isNull(eventTypeDescription_lag)), 'Miss at Vessel and Row',\r",
				"        iif(eventTypeDescription_nxt != 'AYDR' || isNull(eventTypeDescription_nxt), 'DSCH-Miss Arrive at Row',\r",
				"        iif(eventTypeDescription_lag != 'AVCO' || isNull(eventTypeDescription_lag), 'DSCH-Miss Arrive at Vessel', 'No Violation'))),\r",
				"    \r",
				"    toString(null())\r",
				"),",
				"          operatorName = regexReplace(operatorName, `[^a-zA-Z0-9]`, '')) ~> derivedColumn1",
				"select1 alterRow(upsertIf(true())) ~> AlterRow1",
				"derivedColumn1 select(mapColumn(",
				"          ecEventGkey,",
				"          yardGkey = yardgkey,",
				"          YardID = yardid,",
				"          FcyID = fcyid,",
				"          cheKind,",
				"          CHE_Name = cheName,",
				"          eventType = eventtype,",
				"          eventSubType = eventsubtype,",
				"          eventTypeDescription,",
				"          unit,",
				"          pow,",
				"          pool,",
				"          travelDistance = traveldistance,",
				"          moveKind,",
				"          startDistance = startdistance,",
				"          EcEventTime,",
				"          cheID,",
				"          Year,",
				"          Month,",
				"          Week,",
				"          OperatorID = operatorName,",
				"          eventTypeDescription_lag,",
				"          eventTypeDescription_nxt,",
				"          jobStep,",
				"          Types",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"source1 select(mapColumn(",
				"          ecEventGkey,",
				"          yardgkey,",
				"          yardid,",
				"          fcyid,",
				"          cheKind = chekind,",
				"          cheName = che_name,",
				"          cheID = che_id,",
				"          timestamp,",
				"          eventtype,",
				"          eventsubtype,",
				"          eventTypeDescription = eventtypedescription,",
				"          fromcheidname,",
				"          tocheidname,",
				"          unit,",
				"          pow,",
				"          pool,",
				"          workqueue,",
				"          traveldistance,",
				"          moveKind = movekind,",
				"          istwin,",
				"          startdistance,",
				"          workassignment,",
				"          unitref,",
				"          tran_id,",
				"          loctype,",
				"          locid,",
				"          locslot,",
				"          opsposid,",
				"          unladenloctype,",
				"          unladenlocid,",
				"          unladenlocslot,",
				"          ladenloctype,",
				"          ladenlocid,",
				"          laden_locslot,",
				"          lastestmovetime,",
				"          operatorName = operator_name,",
				"          EcEventTime,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"AlterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: 'rsgt',",
				"     folderPath: 'gold/jobstep_missed',",
				"     mergeSchema: true,",
				"     autoCompact: true,",
				"     optimizedWrite: true,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: false,",
				"     updateable: false,",
				"     upsertable: true,",
				"     keys:['ecEventGkey'],",
				"     umask: 0777,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}