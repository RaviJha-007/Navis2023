{
	"name": "WI_01",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "linkedService2",
						"type": "LinkedServiceReference"
					},
					"name": "CSV"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "DataTypeConversions"
				}
			],
			"scriptLines": [
				"parameters{",
				"     p_SourcePath as string ('bronze/workinstruction/load/'),",
				"     p_ClientId as string ('Malta'),",
				"     p_FileSystem as string ('malta')",
				"}",
				"source(output(",
				"          {Unit V-State} as string,",
				"          {Assigned Crane} as string,",
				"          {Intended CHE} as string,",
				"          {State Fetch} as string,",
				"          {Unit Type Length} as string,",
				"          {Unit VGM (kg)} as string,",
				"          {Unit uyvGkey} as long,",
				"          {WI Created} as string,",
				"          {WI Modified} as string,",
				"          {Dest Tz} as string,",
				"          {Unit POL} as string,",
				"          {Unit Position} as string,",
				"          {Unit Rfr Type} as string,",
				"          {Unit Sparcs Notes} as string,",
				"          {Unit Stow} as string,",
				"          {Unit Stow 2} as string,",
				"          {Unit Stow 3} as string,",
				"          {Unit Type ISO} as string,",
				"          {Unit I/B Actual Visit} as string,",
				"          {Unit Impediments Road} as string,",
				"          {Unit Impediments Rail} as string,",
				"          {Unit Impediments Vessel} as string,",
				"          {Unit ISO Grp} as string,",
				"          {Unit Is OOG} as string,",
				"          {Unit Last Free Day} as string,",
				"          {Unit Line Op} as string,",
				"          {Unit Loaded} as string,",
				"          {Unit Must be On-Power} as string,",
				"          {Unit O/B Actual Visit} as string,",
				"          {Unit On Power} as string,",
				"          {Unit POD} as string,",
				"          {Unit Dest} as string,",
				"          {Unit Hazardous:0} as string,",
				"          {Unit Damage Severity} as string,",
				"          {Unit Category} as string,",
				"          Locked as string,",
				"          {MVHS Time Fetch} as string,",
				"          {State Itv Dispatch} as string,",
				"          Modifier as string,",
				"          {Twist Lock} as string,",
				"          {Unit Arrival Booking Number} as string,",
				"          {Unit AutoStrad Suitable} as string,",
				"          {Unit Arrival Position} as string,",
				"          push_rate as string,",
				"          Queue as string,",
				"          mvhs_t_carry_complete as string,",
				"          {MVHS Pool Time Put} as string,",
				"          {EC Hold} as string,",
				"          {N4 To Complete} as string,",
				"          {Nominated CHE} as string,",
				"          {Pushrate Offset} as string,",
				"          {MVHS Time Carry CHE Dispatch} as string,",
				"          {MVHS Rehandle Count} as string,",
				"          {Laden Disp. Requested} as string,",
				"          Definite as string,",
				"          {Confirmed Stage} as string,",
				"          {Assigned Crane CHE Name} as string,",
				"          {Unit T-State} as string,",
				"          {Unit Nbr} as string,",
				"          {Yard Move Deadline} as string,",
				"          Stage as string,",
				"          Kind as string,",
				"          {WI Position} as string,",
				"          {Actual Sequence} as integer,",
				"          Carrier as string,",
				"          {POW Pow Name} as string,",
				"          {Queue Seq.} as integer,",
				"          {MVHS Fetch CHE Id} as string,",
				"          {MVHS Carry CHE Id} as string,",
				"          {MVHS Put CHE Id} as string,",
				"          {Est Mv Time} as string,",
				"          STATUS as string,",
				"          {Twin Fetch} as boolean,",
				"          {Twin Carry} as boolean,",
				"          {Twin Put} as boolean",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     format: 'delimited',",
				"     fileSystem: ($p_FileSystem),",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true,",
				"     wildcardPaths:[($p_SourcePath + 'workinstruction_*.csv')]) ~> CSV",
				"CSV derive({WI Created} = ERROR_FUNCTION('')) ~> DataTypeConversions"
			]
		}
	}
}