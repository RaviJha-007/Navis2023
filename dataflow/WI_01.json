{
	"name": "WI_01",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "linkedService2",
						"type": "LinkedServiceReference"
					},
					"name": "CSV"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "linkedService2",
						"type": "LinkedServiceReference"
					},
					"name": "WISink"
				}
			],
			"transformations": [
				{
					"name": "ColumnNameStandardisation"
				},
				{
					"name": "DateTimeDataTypeConversion"
				},
				{
					"name": "AddingColumns"
				},
				{
					"name": "Filter"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "window1"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"parameters{",
				"     p_SourcePath as string ('bronze/workinstruction/load/'),",
				"     p_ClientId as string ('Malta'),",
				"     p_FileSystem as string ('malta')",
				"}",
				"source(output(",
				"          {Unit V-State} as string,",
				"          {Assigned Crane} as string,",
				"          {Intended CHE} as string,",
				"          {State Fetch} as string,",
				"          {Unit Type Length} as string,",
				"          {Unit VGM (kg)} as string,",
				"          {Unit uyvGkey} as long,",
				"          {WI Created} as string,",
				"          {WI Modified} as string,",
				"          {Dest Tz} as string,",
				"          {Unit POL} as string,",
				"          {Unit Position} as string,",
				"          {Unit Rfr Type} as string,",
				"          {Unit Sparcs Notes} as string,",
				"          {Unit Stow} as string,",
				"          {Unit Stow 2} as string,",
				"          {Unit Stow 3} as string,",
				"          {Unit Type ISO} as string,",
				"          {Unit I/B Actual Visit} as string,",
				"          {Unit Impediments Road} as string,",
				"          {Unit Impediments Rail} as string,",
				"          {Unit Impediments Vessel} as string,",
				"          {Unit ISO Grp} as string,",
				"          {Unit Is OOG} as string,",
				"          {Unit Last Free Day} as string,",
				"          {Unit Line Op} as string,",
				"          {Unit Loaded} as string,",
				"          {Unit Must be On-Power} as string,",
				"          {Unit O/B Actual Visit} as string,",
				"          {Unit On Power} as string,",
				"          {Unit POD} as string,",
				"          {Unit Dest} as string,",
				"          {Unit Hazardous:0} as string,",
				"          {Unit Damage Severity} as string,",
				"          {Unit Category} as string,",
				"          Locked as string,",
				"          {MVHS Time Fetch} as string,",
				"          {State Itv Dispatch} as string,",
				"          Modifier as string,",
				"          {Twist Lock} as string,",
				"          {Unit Arrival Booking Number} as string,",
				"          {Unit AutoStrad Suitable} as string,",
				"          {Unit Arrival Position} as string,",
				"          push_rate as string,",
				"          Queue as string,",
				"          mvhs_t_carry_complete as string,",
				"          {MVHS Pool Time Put} as string,",
				"          {EC Hold} as string,",
				"          {N4 To Complete} as string,",
				"          {Nominated CHE} as string,",
				"          {Pushrate Offset} as string,",
				"          {MVHS Time Carry CHE Dispatch} as string,",
				"          {MVHS Rehandle Count} as string,",
				"          {Laden Disp. Requested} as string,",
				"          Definite as string,",
				"          {Confirmed Stage} as string,",
				"          {Assigned Crane CHE Name} as string,",
				"          {Unit T-State} as string,",
				"          {Unit Nbr} as string,",
				"          {Yard Move Deadline} as string,",
				"          Stage as string,",
				"          Kind as string,",
				"          {WI Position} as string,",
				"          {Actual Sequence} as integer,",
				"          Carrier as string,",
				"          {POW Pow Name} as string,",
				"          {Queue Seq.} as integer,",
				"          {MVHS Fetch CHE Id} as string,",
				"          {MVHS Carry CHE Id} as string,",
				"          {MVHS Put CHE Id} as string,",
				"          {Est Mv Time} as string,",
				"          status as string,",
				"          {Twin Fetch} as boolean,",
				"          {Twin Carry} as boolean,",
				"          {Twin Put} as boolean",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     moveFiles: [($p_SourcePath),'bronze/workinstruction/archive'],",
				"     rowUrlColumn: 'SourceFileName',",
				"     format: 'delimited',",
				"     fileSystem: ($p_FileSystem),",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true,",
				"     wildcardPaths:[($p_SourcePath + 'workinstruction*.csv')]) ~> CSV",
				"CSV select(mapColumn(",
				"          each(match(true()),",
				"               lower(trim(regexReplace($$,'[^a-zA-Z0-9_]','_'),'_')) = $$)",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> ColumnNameStandardisation",
				"ColumnNameStandardisation derive(each(match(in(['wi_created','wi_modified','yard_move_deadline','mvhs_t_carry_complete','mvhs_time_fetch','mvhs_pool_time_put','est_mv_time','mvhs_time_carry_che_dispatch'],name)), $$ = coalesce(",
				"    toTimestamp($$, 'dd/MM/yyyy HH:mm:ss'),",
				"    toTimestamp($$, 'dd/MM/yyyy H:mm:ss'),",
				"    toTimestamp($$, 'dd/MM/yyyy HH:mm'),",
				"    toTimestamp($$, 'dd/MM/yyyy H:mm')",
				"))) ~> DateTimeDataTypeConversion",
				"DateTimeDataTypeConversion derive(integration_key = unit_nbr + '_' + toString(wi_modified,'ddMMyyyyHHmmss'),",
				"          client_id = $p_ClientId,",
				"          load_timestamp = currentTimestamp(),",
				"          source_file_name = regexExtract(sourcefilename, '(\\\\d{8}_\\\\d{4})', 1),",
				"          source_file_name_sort = toLong(concat(regexExtract(sourcefilename, '(\\\\d{2})(\\\\d{2})(\\\\d{4})_(\\\\d{4})', 3), regexExtract(sourcefilename, '(\\\\d{2})(\\\\d{2})(\\\\d{4})_(\\\\d{4})', 2), regexExtract(sourcefilename, '(\\\\d{2})(\\\\d{2})(\\\\d{4})_(\\\\d{4})', 1), regexExtract(sourcefilename, '(\\\\d{2})(\\\\d{2})(\\\\d{4})_(\\\\d{4})', 4))),",
				"          unit_position_type = left(trim(unit_position), 1),",
				"          unit_position_1 = iif(startsWith(trim(unit_position), 'Y') && locate(' ', trim(unit_position)) > 0, regexExtract(trim(unit_position), '^Y-[A-Z0-9]+-([A-Z0-9]+)\\\\s', 1), iif(startsWith(trim(unit_position), 'Y') && locate(' ', trim(unit_position)) == 0, regexExtract(trim(unit_position), '^Y-[A-Z0-9]+-([A-Z0-9]+)$', 1), iif(startsWith(trim(unit_position), 'V'), substring(regexExtract(trim(unit_position), '^V-[0-9]+-([0-9]+)$', 1), 1, 2), ''))),",
				"          unit_position_2 = iif(startsWith(trim(unit_position), 'Y') && locate(' ', trim(unit_position)) > 0, regexExtract(trim(unit_position), '^Y-[A-Z0-9]+-([A-Z0-9]+\\\\s[A-Z0-9]+)', 1), iif(startsWith(trim(unit_position), 'V'), regexExtract(trim(unit_position), '^V-[0-9]+-([0-9]+)$', 1), '')),",
				"          unit_position_3 = iif(startsWith(trim(unit_position), 'Y') && locate(' ', trim(unit_position)) > 0, left(regexExtract(trim(unit_position), '^Y-[A-Z0-9]+-([A-Z0-9]+\\\\s[A-Z0-9]+\\\\s[A-Z0-9]+)', 1), length(regexExtract(trim(unit_position), '^Y-[A-Z0-9]+-([A-Z0-9]+\\\\s[A-Z0-9]+\\\\s[A-Z0-9]+)', 1)) - 1), iif(startsWith(trim(unit_position), 'V'), substring(regexExtract(trim(unit_position), '^V-[0-9]+-([0-9]+)$', 1), 1, 4), '')),",
				"          unit_position_4 = iif(startsWith(trim(unit_position), 'Y') && locate(' ', trim(unit_position)) > 0, right(trim(unit_position), 1), iif(startsWith(trim(unit_position), 'V'), right(regexExtract(trim(unit_position), '^V-[0-9]+-([0-9]+)$', 1), 2), '')),",
				"          unit_tier_num = iif(startsWith(trim(unit_position), 'Y') && locate(' ', trim(unit_position)) > 0, toInteger(ascii(right(trim(unit_position), 1))) - toInteger(ascii('A')) + 1, iif(startsWith(trim(unit_position), 'V'), toInteger(right(regexExtract(trim(unit_position), '^V-[0-9]+-([0-9]+)$', 1), 2)), 0)),",
				"          wi_position_type = left(trim(wi_position), 1),",
				"          wi_position_1 = iif(startsWith(trim(wi_position), 'Y') && locate(' ', trim(wi_position)) > 0, regexExtract(trim(wi_position), '^Y-[A-Z0-9]+-([A-Z0-9]+)\\\\s', 1), iif(startsWith(trim(wi_position), 'Y') && locate(' ', trim(wi_position)) == 0, regexExtract(trim(wi_position), '^Y-[A-Z0-9]+-([A-Z0-9]+)$', 1), iif(startsWith(trim(wi_position), 'V'), substring(regexExtract(trim(wi_position), '^V-[0-9]+-([0-9]+)$', 1), 1, 2), ''))),",
				"          wi_position_2 = iif(startsWith(trim(wi_position), 'Y') && locate(' ', trim(wi_position)) > 0, regexExtract(trim(wi_position), '^Y-[A-Z0-9]+-([A-Z0-9]+\\\\s[A-Z0-9]+)', 1), iif(startsWith(trim(wi_position), 'V'), regexExtract(trim(wi_position), '^V-[0-9]+-([0-9]+)$', 1), '')),",
				"          wi_position_3 = iif(startsWith(trim(wi_position), 'Y') && locate(' ', trim(wi_position)) > 0, left(regexExtract(trim(wi_position), '^Y-[A-Z0-9]+-([A-Z0-9]+\\\\s[A-Z0-9]+\\\\s[A-Z0-9]+)', 1), length(regexExtract(trim(wi_position), '^Y-[A-Z0-9]+-([A-Z0-9]+\\\\s[A-Z0-9]+\\\\s[A-Z0-9]+)', 1)) - 1), iif(startsWith(trim(wi_position), 'V'), substring(regexExtract(trim(wi_position), '^V-[0-9]+-([0-9]+)$', 1), 1, 4), '')),",
				"          wi_position_4 = iif(startsWith(trim(wi_position), 'Y') && locate(' ', trim(wi_position)) > 0, right(trim(wi_position), 1), iif(startsWith(trim(wi_position), 'V'), right(regexExtract(trim(wi_position), '^V-[0-9]+-([0-9]+)$', 1), 2), '')),",
				"          wi_tier_num = iif(startsWith(trim(wi_position), 'Y') && locate(' ', trim(wi_position)) > 0, toInteger(ascii(right(trim(wi_position), 1))) - toInteger(ascii('A')) + 1, iif(startsWith(trim(wi_position), 'V'), toInteger(right(regexExtract(trim(wi_position), '^V-[0-9]+-([0-9]+)$', 1), 2)), 0)),",
				"          year = year(wi_modified),",
				"          month = month(wi_modified),",
				"          week = weekOfYear(wi_modified)) ~> AddingColumns",
				"AddingColumns filter(!isNull(integration_key)) ~> Filter",
				"filter1 alterRow(upsertIf(true())) ~> alterRow1",
				"Filter window(over(integration_key),",
				"     desc(source_file_name_sort, true),",
				"     row_number = rowNumber()) ~> window1",
				"window1 filter(row_number == 1) ~> filter1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          unit_v_state as string,",
				"          assigned_crane as string,",
				"          intended_che as string,",
				"          state_fetch as string,",
				"          unit_type_length as string,",
				"          unit_vgm__kg as string,",
				"          unit_uyvgkey as long,",
				"          wi_created as timestamp,",
				"          wi_modified as timestamp,",
				"          dest_tz as string,",
				"          unit_pol as string,",
				"          unit_position as string,",
				"          unit_rfr_type as string,",
				"          unit_sparcs_notes as string,",
				"          unit_stow as string,",
				"          unit_stow_2 as string,",
				"          unit_stow_3 as string,",
				"          unit_type_iso as string,",
				"          unit_i_b_actual_visit as string,",
				"          unit_impediments_road as string,",
				"          unit_impediments_rail as string,",
				"          unit_impediments_vessel as string,",
				"          unit_iso_grp as string,",
				"          unit_is_oog as string,",
				"          unit_last_free_day as string,",
				"          unit_line_op as string,",
				"          unit_loaded as string,",
				"          unit_must_be_on_power as string,",
				"          unit_o_b_actual_visit as string,",
				"          unit_on_power as string,",
				"          unit_pod as string,",
				"          unit_dest as string,",
				"          unit_hazardous_0 as string,",
				"          unit_damage_severity as string,",
				"          unit_category as string,",
				"          locked as string,",
				"          mvhs_time_fetch as timestamp,",
				"          state_itv_dispatch as string,",
				"          modifier as string,",
				"          twist_lock as string,",
				"          unit_arrival_booking_number as string,",
				"          unit_autostrad_suitable as string,",
				"          unit_arrival_position as string,",
				"          push_rate as string,",
				"          queue as string,",
				"          mvhs_t_carry_complete as timestamp,",
				"          mvhs_pool_time_put as timestamp,",
				"          ec_hold as string,",
				"          n4_to_complete as string,",
				"          nominated_che as string,",
				"          pushrate_offset as string,",
				"          mvhs_time_carry_che_dispatch as timestamp,",
				"          mvhs_rehandle_count as string,",
				"          laden_disp__requested as string,",
				"          definite as string,",
				"          confirmed_stage as string,",
				"          assigned_crane_che_name as string,",
				"          unit_t_state as string,",
				"          unit_nbr as string,",
				"          yard_move_deadline as timestamp,",
				"          stage as string,",
				"          kind as string,",
				"          wi_position as string,",
				"          actual_sequence as integer,",
				"          carrier as string,",
				"          pow_pow_name as string,",
				"          queue_seq as integer,",
				"          mvhs_fetch_che_id as string,",
				"          mvhs_carry_che_id as string,",
				"          mvhs_put_che_id as string,",
				"          est_mv_time as timestamp,",
				"          status as string,",
				"          twin_fetch as boolean,",
				"          twin_carry as boolean,",
				"          twin_put as boolean,",
				"          sourcefilename as string,",
				"          integration_key as string,",
				"          client_id as string,",
				"          load_timestamp as timestamp,",
				"          source_file_name as string,",
				"          source_file_name_sort as long,",
				"          unit_position_type as string,",
				"          unit_position_1 as string,",
				"          unit_position_2 as string,",
				"          unit_position_3 as string,",
				"          unit_position_4 as string,",
				"          unit_tier_num as integer,",
				"          wi_position_type as string,",
				"          wi_position_1 as string,",
				"          wi_position_2 as string,",
				"          wi_position_3 as string,",
				"          wi_position_4 as string,",
				"          wi_tier_num as integer,",
				"          year as integer,",
				"          month as integer,",
				"          week as integer,",
				"          row_number as integer",
				"     ),",
				"     format: 'delta',",
				"     fileSystem: ($p_FileSystem),",
				"     folderPath: 'silver/workinstruction/',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: false,",
				"     updateable: false,",
				"     upsertable: true,",
				"     keys:['integration_key'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> WISink"
			]
		}
	}
}