{
	"name": "WI_01",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "linkedService2",
						"type": "LinkedServiceReference"
					},
					"name": "CSV"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "linkedService2",
						"type": "LinkedServiceReference"
					},
					"name": "WISink"
				}
			],
			"transformations": [
				{
					"name": "ColumnNameStandardisation"
				},
				{
					"name": "DateTimeDataTypeConversion"
				},
				{
					"name": "AddingColumns"
				},
				{
					"name": "Filter"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "window1"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"parameters{",
				"     p_SourcePath as string ('bronze/workinstruction/load/'),",
				"     p_ClientId as string ('Malta'),",
				"     p_FileSystem as string (@pipeline().parameters.p_TriggeredFileSystem)",
				"}",
				"source(output(",
				"          {Unit V-State} as string,",
				"          {Assigned Crane} as string,",
				"          {Intended CHE} as string,",
				"          {State Fetch} as string,",
				"          {Unit Type Length} as string,",
				"          {Unit VGM (kg)} as string,",
				"          {Unit uyvGkey} as long,",
				"          {WI Created} as string,",
				"          {WI Modified} as string,",
				"          {Dest Tz} as string,",
				"          {Unit POL} as string,",
				"          {Unit Position} as string,",
				"          {Unit Rfr Type} as string,",
				"          {Unit Sparcs Notes} as string,",
				"          {Unit Stow} as string,",
				"          {Unit Stow 2} as string,",
				"          {Unit Stow 3} as string,",
				"          {Unit Type ISO} as string,",
				"          {Unit I/B Actual Visit} as string,",
				"          {Unit Impediments Road} as string,",
				"          {Unit Impediments Rail} as string,",
				"          {Unit Impediments Vessel} as string,",
				"          {Unit ISO Grp} as string,",
				"          {Unit Is OOG} as string,",
				"          {Unit Last Free Day} as string,",
				"          {Unit Line Op} as string,",
				"          {Unit Loaded} as string,",
				"          {Unit Must be On-Power} as string,",
				"          {Unit O/B Actual Visit} as string,",
				"          {Unit On Power} as string,",
				"          {Unit POD} as string,",
				"          {Unit Dest} as string,",
				"          {Unit Hazardous:0} as string,",
				"          {Unit Damage Severity} as string,",
				"          {Unit Category} as string,",
				"          Locked as string,",
				"          {MVHS Time Fetch} as string,",
				"          {State Itv Dispatch} as string,",
				"          Modifier as string,",
				"          {Twist Lock} as string,",
				"          {Unit Arrival Booking Number} as string,",
				"          {Unit AutoStrad Suitable} as string,",
				"          {Unit Arrival Position} as string,",
				"          push_rate as string,",
				"          Queue as string,",
				"          mvhs_t_carry_complete as string,",
				"          {MVHS Pool Time Put} as string,",
				"          {EC Hold} as string,",
				"          {N4 To Complete} as string,",
				"          {Nominated CHE} as string,",
				"          {Pushrate Offset} as string,",
				"          {MVHS Time Carry CHE Dispatch} as string,",
				"          {MVHS Rehandle Count} as string,",
				"          {Laden Disp. Requested} as string,",
				"          Definite as string,",
				"          {Confirmed Stage} as string,",
				"          {Assigned Crane CHE Name} as string,",
				"          {Unit T-State} as string,",
				"          {Unit Nbr} as string,",
				"          {Yard Move Deadline} as string,",
				"          Stage as string,",
				"          Kind as string,",
				"          {WI Position} as string,",
				"          {Actual Sequence} as integer,",
				"          Carrier as string,",
				"          {POW Pow Name} as string,",
				"          {Queue Seq.} as integer,",
				"          {MVHS Fetch CHE Id} as string,",
				"          {MVHS Carry CHE Id} as string,",
				"          {MVHS Put CHE Id} as string,",
				"          {Est Mv Time} as string,",
				"          STATUS as string,",
				"          {Twin Fetch} as boolean,",
				"          {Twin Carry} as boolean,",
				"          {Twin Put} as boolean",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     moveFiles: [($p_SourcePath),'bronze/workinstruction/archive'],",
				"     rowUrlColumn: 'SourceFileName',",
				"     format: 'delimited',",
				"     fileSystem: ($p_FileSystem),",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true,",
				"     wildcardPaths:[($p_SourcePath + 'workinstruction_*.csv')]) ~> CSV",
				"CSV select(mapColumn(",
				"          each(match(/* All input columns */ true()),",
				"               trim(regexReplace($$, '[^a-zA-Z0-9_]', '_'), '_') = $$)",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> ColumnNameStandardisation",
				"ColumnNameStandardisation derive(each(match( in(['WI_Created', 'WI_Modified', 'Yard_Move_Deadline', 'mvhs_t_carry_complete', 'MVHS_Time_Fetch', 'MVHS_Pool_Time_Put', 'Est_Mv_Time', 'MVHS_Time_Carry_CHE_Dispatch'], name)), $$ = coalesce(\r",
				"    toTimestamp($$, 'dd/MM/yyyy HH:mm:ss'),\r",
				"    toTimestamp($$, 'dd/MM/yyyy H:mm:ss'),\r",
				"    toTimestamp($$, 'dd/MM/yyyy HH:mm'),\r",
				"    toTimestamp($$, 'dd/MM/yyyy H:mm')\r",
				"))) ~> DateTimeDataTypeConversion",
				"DateTimeDataTypeConversion derive(IntegrationKey = Unit_Nbr + '_' + toString(WI_Modified,'ddMMyyyyHHmmss'),",
				"          ClientId = $p_ClientId,",
				"          Load_TimeStamp = currentTimestamp(),",
				"          SourceFileName = regexExtract(SourceFileName, '(\\\\d{8}_\\\\d{4})', 1),",
				"          SourceFileName_Sort = toLong(     concat(         regexExtract(SourceFileName, '(\\\\d{2})(\\\\d{2})(\\\\d{4})_(\\\\d{4})', 3),         regexExtract(SourceFileName, '(\\\\d{2})(\\\\d{2})(\\\\d{4})_(\\\\d{4})', 2),         regexExtract(SourceFileName, '(\\\\d{2})(\\\\d{2})(\\\\d{4})_(\\\\d{4})', 1),         regexExtract(SourceFileName, '(\\\\d{2})(\\\\d{2})(\\\\d{4})_(\\\\d{4})', 4)     ) ),",
				"          Unit_Position_1 = regexExtract(Unit_Position, '^.*-([A-Z0-9]+)\\\\s([A-Z0-9]+)\\\\s([A-Z0-9]+)$', 1),",
				"          Unit_Position_2 = regexExtract(Unit_Position, '^.*-([A-Z0-9]+)\\\\s([A-Z0-9]+)\\\\s([A-Z0-9]+)$', 2),",
				"          Unit_Position_3 = regexExtract(Unit_Position, '^.*-([A-Z0-9]+)\\\\s([A-Z0-9]+)\\\\s([A-Z0-9]+)$', 3),",
				"          WI_Position_1 = regexExtract(WI_Position, '^.*-([A-Z0-9]+)\\\\s([A-Z0-9]+)\\\\s([A-Z0-9]+)$', 1),",
				"          WI_Position_2 = regexExtract(WI_Position, '^.*-([A-Z0-9]+)\\\\s([A-Z0-9]+)\\\\s([A-Z0-9]+)$', 2),",
				"          WI_Position_3 = regexExtract(WI_Position, '^.*-([A-Z0-9]+)\\\\s([A-Z0-9]+)\\\\s([A-Z0-9]+)$', 3),",
				"          Year = year(WI_Modified),",
				"          Month = month(WI_Modified),",
				"          Week = weekOfYear(WI_Modified)) ~> AddingColumns",
				"AddingColumns filter(!isNull(IntegrationKey)) ~> Filter",
				"filter1 alterRow(upsertIf(true())) ~> alterRow1",
				"Filter window(over(IntegrationKey),",
				"     desc(SourceFileName_Sort, true),",
				"     RowNumber = rowNumber()) ~> window1",
				"window1 filter(RowNumber == 1) ~> filter1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: ($p_FileSystem),",
				"     folderPath: 'silver/workinstruction/',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: false,",
				"     updateable: false,",
				"     upsertable: true,",
				"     keys:['IntegrationKey'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('key',",
				"          1,",
				"          Year,",
				"          Month,",
				"          Week",
				"     )) ~> WISink"
			]
		}
	}
}