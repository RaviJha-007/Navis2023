{
	"name": "itv_productivity_RSGT",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "linkedService1",
						"type": "LinkedServiceReference"
					},
					"name": "moves"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "linkedService1",
						"type": "LinkedServiceReference"
					},
					"name": "ItvProductivity"
				},
				{
					"linkedService": {
						"referenceName": "linkedService2",
						"type": "LinkedServiceReference"
					},
					"name": "ItvWorkhours"
				}
			],
			"transformations": [
				{
					"name": "aggregate2"
				},
				{
					"name": "ItvMoves"
				},
				{
					"name": "select3"
				},
				{
					"name": "derivedColumn8"
				},
				{
					"name": "window1"
				},
				{
					"name": "derivedColumn9"
				},
				{
					"name": "derivedColumn10"
				},
				{
					"name": "derivedColumn11"
				},
				{
					"name": "aggregate4"
				},
				{
					"name": "alterRow3"
				},
				{
					"name": "alterRow4"
				},
				{
					"name": "select5"
				},
				{
					"name": "derivedColumn12"
				}
			],
			"scriptLines": [
				"parameters{",
				"     Customer as string ('rsgt')",
				"}",
				"source(output(",
				"          mve_gkey as long,",
				"          Unit_Nbr as string,",
				"          Facility_Id as string,",
				"          Complex_Id as string,",
				"          Yard_Id as string,",
				"          Carrier_Visit_Key as long,",
				"          Event_Type_Id as string,",
				"          Move_Kind as string,",
				"          From_Location as string,",
				"          To_Location as string,",
				"          From_Position_Name as string,",
				"          To_Position_Name as string,",
				"          Carry_CHE_Operator_Id as integer,",
				"          Fetch_CHE_Operator_Id as string,",
				"          Put_CHE_Operator_Id as string,",
				"          Fetch_CHE_Id as long,",
				"          Fetch_CHE_Kind as string,",
				"          Carry_CHE_Id as long,",
				"          Carry_CHE_Kind as string,",
				"          Put_CHE_Id as long,",
				"          Put_CHE_Kind as string,",
				"          QC_CHE_Id as long,",
				"          QC_CHE_Kind as string,",
				"          t_carry_complete as timestamp,",
				"          t_put as timestamp,",
				"          t_fetch as timestamp,",
				"          t_dispatch as timestamp,",
				"          t_discharge as timestamp,",
				"          t_carry_dispatch as timestamp,",
				"          t_carry_fetch_ready as timestamp,",
				"          t_carry_put_ready as timestamp,",
				"          dist_carry as short,",
				"          dist_start as integer,",
				"          Twin_Fetch as boolean,",
				"          Twin_Carry as boolean,",
				"          Twin_Put as boolean,",
				"          Category_Id as string,",
				"          Freight_Kind_Id as string,",
				"          to_pos_gkey as long,",
				"          fm_pos_gkey as long,",
				"          Restow_Reason as string,",
				"          Container_Line_Id as string,",
				"          Container_Line_Role as string,",
				"          pow as string,",
				"          ufv_gkey as long,",
				"          Berth_Id as string,",
				"          Goods_And_Ctr_Wt_Kg as double,",
				"          active_ufv as long,",
				"          Requires_Power_Flag as boolean,",
				"          OOG_Flag as boolean,",
				"          Shipper_Id as string,",
				"          Consignee_Id as string,",
				"          Commodity_Id as string,",
				"          ATA as timestamp,",
				"          ATD as timestamp,",
				"          Rehandles as short,",
				"          Date as date,",
				"          Year as integer,",
				"          Month as integer,",
				"          Week as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'silver/moves') ~> moves",
				"moves aggregate(groupBy(mve_gkey),",
				"     each(match(name!='mve_gkey'), $$ = first($$))) ~> aggregate2",
				"aggregate2 filter(not(isNull(mve_gkey)) && in([\"DLVR\",\"LOAD\",\"SHFT\",\"DSCH\",\"RECV\", \"YARD\"], Move_Kind) && Carry_CHE_Kind==\"ITV\" && not(isNull(Carry_CHE_Id)) && not(isNull(t_put))) ~> ItvMoves",
				"ItvMoves select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          From_Position_Name,",
				"          To_Position_Name,",
				"          CHE_Operator_Id = Carry_CHE_Operator_Id,",
				"          CHE_Id = Carry_CHE_Id,",
				"          CHE_Kind = Carry_CHE_Kind,",
				"          move_time = t_carry_complete,",
				"          t_put,",
				"          dist_carry,",
				"          dist_start,",
				"          valid_twin_flag = Twin_Carry,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          Berth_Id,",
				"          Shipper_Id,",
				"          Consignee_Id,",
				"          Commodity_Id,",
				"          Date,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"select3 derive(move_date = toDate(move_time)) ~> derivedColumn8",
				"derivedColumn8 window(over(CHE_Id),",
				"     asc(move_time, true),",
				"     prev_move_time = lag(move_time,1)) ~> window1",
				"window1 derive(moves_gap_seconds = (toLong(move_time) - toLong(prev_move_time))/1000) ~> derivedColumn9",
				"derivedColumn9 derive(new_move_session_flag = iif(isNull(prev_move_time) || moves_gap_seconds > 10800 ,1,0)) ~> derivedColumn10",
				"derivedColumn10 derive(Worktime_Seconds = iif(new_move_session_flag==1, toLong(0), moves_gap_seconds)) ~> derivedColumn11",
				"derivedColumn11 aggregate(groupBy(CHE_Id,",
				"          CHE_Kind,",
				"          Year,",
				"          Month,",
				"          Week,",
				"          move_date),",
				"     Total_Moves = countDistinct(Move_Primary_key),",
				"          Twin_Count = countIf(valid_twin_flag, Move_Primary_key),",
				"          Total_Work_Seconds = sum(Worktime_Seconds)) ~> aggregate4",
				"derivedColumn12 alterRow(upsertIf(true())) ~> alterRow3",
				"select5 alterRow(upsertIf(true())) ~> alterRow4",
				"derivedColumn11 select(mapColumn(",
				"          Move_Primary_key,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          From_Position_Name,",
				"          To_Position_Name,",
				"          CHE_Operator_Id,",
				"          CHE_Id,",
				"          CHE_Kind,",
				"          move_time,",
				"          t_put,",
				"          dist_carry,",
				"          dist_start,",
				"          valid_twin_flag,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          Berth_Id,",
				"          Shipper_Id,",
				"          Consignee_Id,",
				"          Commodity_Id,",
				"          Date,",
				"          Year,",
				"          Month,",
				"          Week,",
				"          move_date,",
				"          prev_move_time,",
				"          moves_gap_seconds,",
				"          new_move_session_flag,",
				"          Worktime_Seconds",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select5",
				"aggregate4 derive(Productive_Moves = Total_Moves-(Twin_Count/2)) ~> derivedColumn12",
				"alterRow3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'gold/itv_productivity',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: false,",
				"     updateable: false,",
				"     upsertable: true,",
				"     keys:['move_date','CHE_Id'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> ItvProductivity",
				"alterRow4 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'gold/itv_hours_moves',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: false,",
				"     updateable: false,",
				"     upsertable: true,",
				"     keys:['Move_Primary_key'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> ItvWorkhours"
			]
		}
	}
}