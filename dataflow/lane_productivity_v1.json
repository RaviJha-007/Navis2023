{
	"name": "lane_productivity_v1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "linkedService1",
						"type": "LinkedServiceReference"
					},
					"name": "moves"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "linkedService1",
						"type": "LinkedServiceReference"
					},
					"name": "LaneProd"
				}
			],
			"transformations": [
				{
					"name": "aggregate2"
				},
				{
					"name": "filter3"
				},
				{
					"name": "split1"
				},
				{
					"name": "split2"
				},
				{
					"name": "select2"
				},
				{
					"name": "select3"
				},
				{
					"name": "select4"
				},
				{
					"name": "select6Put"
				},
				{
					"name": "select5Fetch"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "union1"
				},
				{
					"name": "aggregate"
				},
				{
					"name": "AlterRow3"
				},
				{
					"name": "aggregate3"
				},
				{
					"name": "derivedColumn7"
				},
				{
					"name": "derivedColumn8"
				},
				{
					"name": "derivedColumn9"
				},
				{
					"name": "select5"
				},
				{
					"name": "filter4"
				},
				{
					"name": "derivedColumn10"
				},
				{
					"name": "derivedColumn11"
				},
				{
					"name": "derivedColumn12"
				}
			],
			"scriptLines": [
				"parameters{",
				"     Customer as string ('apmt-salalah')",
				"}",
				"source(output(",
				"          mve_gkey as long,",
				"          Unit_Nbr as string,",
				"          Facility_Id as string,",
				"          Yard_Id as string,",
				"          Carrier_Visit_Key as long,",
				"          Event_Type_Id as string,",
				"          Move_Kind as string,",
				"          From_Location as string,",
				"          To_Location as string,",
				"          From_Position_Name as string,",
				"          To_Position_Name as string,",
				"          Carry_CHE_Operator_Id as string,",
				"          Fetch_CHE_Operator_Id as string,",
				"          Put_CHE_Operator_Id as string,",
				"          Fetch_CHE_Id as long,",
				"          Fetch_CHE_Kind as string,",
				"          Carry_CHE_Id as long,",
				"          Carry_CHE_Kind as string,",
				"          Put_CHE_Id as long,",
				"          Put_CHE_Kind as string,",
				"          QC_CHE_Id as long,",
				"          QC_CHE_Kind as string,",
				"          t_carry_complete as timestamp,",
				"          t_put as timestamp,",
				"          t_fetch as timestamp,",
				"          t_dispatch as timestamp,",
				"          t_discharge as timestamp,",
				"          t_carry_dispatch as timestamp,",
				"          t_carry_fetch_ready as timestamp,",
				"          t_carry_put_ready as timestamp,",
				"          dist_carry as integer,",
				"          dist_start as integer,",
				"          Twin_Fetch as boolean,",
				"          Twin_Carry as boolean,",
				"          Twin_Put as boolean,",
				"          Category_Id as string,",
				"          Freight_Kind_Id as string,",
				"          Restow_Reason as string,",
				"          POW as string,",
				"          ufv_gkey as long,",
				"          Goods_And_Ctr_Wt_Kg as integer,",
				"          Requires_Power_Flag as boolean,",
				"          OOG_Flag as boolean,",
				"          ATA as timestamp,",
				"          ATD as timestamp,",
				"          Rehandles as short,",
				"          Year as integer,",
				"          Month as integer,",
				"          Week as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'silver/moves') ~> moves",
				"moves aggregate(groupBy(mve_gkey),",
				"     each(match(name!='mve_gkey'), $$ = first($$))) ~> aggregate2",
				"aggregate2 filter(not(isNull(mve_gkey))) ~> filter3",
				"derivedColumn9 split(in([\"DLVR\",\"LOAD\",\"SHFT\"], Move_Kind) && Fetch_CHE_Kind==\"RTG\" && not(isNull(Fetch_CHE_Id)),",
				"     in([\"DSCH\",\"RECV\"], Move_Kind) && Put_CHE_Kind==\"RTG\"  && not(isNull(Put_CHE_Id)),",
				"     Move_Kind==\"YARD\",",
				"     disjoint: true) ~> split1@(LSD, RD, Y)",
				"split1@Y split((Fetch_CHE_Kind==\"RTG\" || Put_CHE_Kind==\"RTG\") && Fetch_CHE_Id==Put_CHE_Id && not(isNull(Put_CHE_Id)),",
				"     (Fetch_CHE_Kind==\"RTG\" || Put_CHE_Kind==\"RTG\") && Fetch_CHE_Id!=Put_CHE_Id && not(isNull(Fetch_CHE_Id)) && not(isNull(Put_CHE_Id)),",
				"     disjoint: true) ~> split2@(YE, YNE)",
				"split1@LSD select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          Position_Name = From_Position_Name,",
				"          CHE_Operator_Id = Fetch_CHE_Operator_Id,",
				"          CHE_Id = Fetch_CHE_Id,",
				"          CHE_Kind = Fetch_CHE_Kind,",
				"          move_time = t_fetch,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow = POW,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"split1@RD select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          Position_Name = To_Position_Name,",
				"          CHE_Operator_Id = Put_CHE_Operator_Id,",
				"          CHE_Id = Put_CHE_Id,",
				"          CHE_Kind = Put_CHE_Kind,",
				"          move_time = t_put,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow = POW,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"split2@YE select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          Position_Name = To_Position_Name,",
				"          CHE_Operator_Id = Put_CHE_Operator_Id,",
				"          CHE_Id = Put_CHE_Id,",
				"          CHE_Kind = Put_CHE_Kind,",
				"          move_time = t_put,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow = POW,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4",
				"split2@YNE select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          Position_Name = To_Position_Name,",
				"          CHE_Operator_Id = Put_CHE_Operator_Id,",
				"          CHE_Id = Put_CHE_Id,",
				"          CHE_Kind = Put_CHE_Kind,",
				"          move_time = t_put,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow = POW,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select6Put",
				"split2@YNE select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          Position_Name = From_Position_Name,",
				"          CHE_Operator_Id = Fetch_CHE_Operator_Id,",
				"          CHE_Id = Fetch_CHE_Id,",
				"          CHE_Kind = Fetch_CHE_Kind,",
				"          move_time = t_fetch,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          ufv_gkey,",
				"          pow = POW,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select5Fetch",
				"select5Fetch derive(Move_Primary_key = toString(Move_Primary_key) + \"-\" + toString(CHE_Kind) + \"-\" + toString(CHE_Id)) ~> derivedColumn4",
				"select6Put derive(Move_Primary_key = toString(Move_Primary_key) + \"-\" + toString(CHE_Kind) + \"-\" + toString(CHE_Id)) ~> derivedColumn5",
				"select3, select4, select2, derivedColumn4, derivedColumn5 union(byName: true)~> union1",
				"union1 aggregate(groupBy(Move_Primary_key),",
				"     each(match(name!='Move_Primary_key'), $$ = first($$))) ~> aggregate",
				"derivedColumn7 alterRow(upsertIf(true())) ~> AlterRow3",
				"derivedColumn11 aggregate(groupBy(Lane_Name,",
				"          Year,",
				"          Month,",
				"          Week,",
				"          move_date,",
				"          move_hour),",
				"     Move_count = countDistinct(Move_Primary_key),",
				"          First_Lift = min(move_time),",
				"          Last_Lift = max(move_time),",
				"          ActiveRTGCount = countDistinct(CHE_Id)) ~> aggregate3",
				"aggregate3 derive(Worktime_Seconds = :worktime_seconds,",
				"          Lift_Diff = :lift_diff,",
				"          WorkTime = iif((isNull(Last_Lift) || isNull(First_Lift) || isNull(:lift_diff) || :lift_diff<=0 || :lift_diff >=3600000),:worktime_seconds,:lift_diff),",
				"          lift_diff := toInteger(toLong(Last_Lift) - toLong(First_Lift)),",
				"          worktime_seconds := iif(Move_count>=1, 3600000,0)) ~> derivedColumn7",
				"aggregate derive(move_date = toDate(move_time),",
				"          move_hour = toInteger(split(toString(move_time,'HH:mm:ss'),\":\")[1]),",
				"          Block_Id = :position,",
				"          Lane_Number = left(:position,2),",
				"          Lane_Id = upper(right(:position,1)),",
				"          position := left(split(Position_Name, \"-\")[3], 3)) ~> derivedColumn8",
				"filter3 derive(mve_gkey = toString(mve_gkey)) ~> derivedColumn9",
				"derivedColumn12 select(mapColumn(",
				"          Move_Primary_key,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          Position_Name,",
				"          CHE_Operator_Id,",
				"          CHE_Id,",
				"          CHE_Kind,",
				"          move_time,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week,",
				"          move_date,",
				"          move_hour,",
				"          Block_Id,",
				"          Lane_Number,",
				"          Lane_Id,",
				"          Block_Type",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select5",
				"derivedColumn8 filter(((Lane_Id >='A' && Lane_Id<='H') && in([\"01\",\"02\",\"03\",\"05\",\"06\",\"Z6\"], Lane_Number)) || in([\"03S\",\"03R\",\"04A\",\"04B\",\"04C\",\"04D\",\"04E\",\"04F\"],Block_Id)) ~> filter4",
				"filter4 derive(Block_Type = iif(in(:{7WideBlocks},Block_Id), \"7 Wide\", iif(in(:RSTBlocks,Block_Id), \"RST\", \"6 Wide\")),",
				"          {7WideBlocks} := [\"01H\",\"02H\",\"03H\",\"01G\",\"02G\",\"03G\",\"01E\",\"02E\",\"03E\",\"04E\",\"01C\",\"02C\",\"03C\",\"04C\"],",
				"          RSTBlocks := [\"03S\",\"03R\"]) ~> derivedColumn10",
				"select5 derive(Lane_Name = iif(Block_Type==\"RST\", Block_Type, Lane_Id + \": \"+ Block_Type)) ~> derivedColumn11",
				"derivedColumn10 derive(Lane_Name = iif(Block_Type==\"RST\", \"RST\", \"{Lane_Id}\"+':' +\" {Block_Type}\")) ~> derivedColumn12",
				"AlterRow3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'gold/lane_productivity',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: false,",
				"     updateable: false,",
				"     upsertable: true,",
				"     keys:['Year','Month','Week','Date','cheID','cheName'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> LaneProd"
			]
		}
	}
}