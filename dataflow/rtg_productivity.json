				}
			],
			"scriptLines": [
				"parameters{",
				"     Customer as string ('itapoa')",
				"}",
				"source(output(",
				"          ecEventGkey as long,",
				"          yardGkey as string,",
				"          YardID as string,",
				"          FcyID as string,",
				"          cheKind as string,",
				"          CHE_Name as string,",
				"          eventType as string,",
				"          eventSubType as string,",
				"          eventTypeDescription as string,",
				"          fromCheIdName as string,",
				"          ToCheIdName as string,",
				"          unit as string,",
				"          pow as string,",
				"          pool as string,",
				"          workQueue as string,",
				"          travelDistance as string,",
				"          moveKind as string,",
				"          isTwin as string,",
				"          startDistance as string,",
				"          unitRef as string,",
				"          tran_ID as string,",
				"          locType as string,",
				"          locID as string,",
				"          locSlot as string,",
				"          opsPosID as string,",
				"          unladenLoctype as string,",
				"          unladenLocID as string,",
				"          unladenLocSlot as string,",
				"          ladenLoctype as string,",
				"          ladenLocID as string,",
				"          laden_LocSlot as string,",
				"          operator as string,",
				"          EcEventTime as timestamp,",
				"          cheID as long,",
				"          Year as integer,",
				"          Month as integer,",
				"          Week as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'silver/ecevents') ~> ecevents",
				"source(output(",
				"          mve_gkey as string,",
				"          Unit_Nbr as string,",
				"          Facility_Id as string,",
				"          Complex_Id as string,",
				"          Yard_Id as string,",
				"          Carrier_Visit_Key as string,",
				"          Event_Type_Id as string,",
				"          Move_Kind as string,",
				"          From_Location as string,",
				"          To_Location as string,",
				"          From_Position_Name as string,",
				"          To_Position_Name as string,",
				"          Carry_CHE_Operator_Id as string,",
				"          Fetch_CHE_Operator_Id as string,",
				"          Put_CHE_Operator_Id as string,",
				"          Fetch_CHE_Id as long,",
				"          Fetch_CHE_Kind as string,",
				"          Carry_CHE_Id as long,",
				"          Carry_CHE_Kind as string,",
				"          Put_CHE_Id as long,",
				"          Put_CHE_Kind as string,",
				"          QC_CHE_Id as long,",
				"          QC_CHE_Kind as string,",
				"          t_carry_complete as timestamp,",
				"          t_put as timestamp,",
				"          t_fetch as timestamp,",
				"          t_dispatch as timestamp,",
				"          t_discharge as timestamp,",
				"          t_carry_dispatch as timestamp,",
				"          t_carry_fetch_ready as timestamp,",
				"          t_carry_put_ready as timestamp,",
				"          dist_carry as string,",
				"          dist_start as string,",
				"          Twin_Fetch as string,",
				"          Twin_Carry as string,",
				"          Twin_Put as string,",
				"          Category_Id as string,",
				"          Freight_Kind_Id as string,",
				"          to_pos_gkey as string,",
				"          fm_pos_gkey as string,",
				"          Restow_Reason as string,",
				"          Container_Line_Id as string,",
				"          Container_Line_Role as string,",
				"          pow as string,",
				"          ufv_gkey as string,",
				"          Berth_Id as string,",
				"          Goods_And_Ctr_Wt_Kg as string,",
				"          active_ufv as string,",
				"          Requires_Power_Flag as string,",
				"          OOG_Flag as string,",
				"          Shipper_Id as string,",
				"          Consignee_Id as string,",
				"          Commodity_Id as string,",
				"          ATD as timestamp,",
				"          Rehandles as string,",
				"          ATA as timestamp,",
				"          Year as integer,",
				"          Month as integer,",
				"          Week as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'silver/moves') ~> moves",
				"aggregate1 filter(not(isNull(ecEventGkey)) && cheKind == 'RTG' && (eventTypeDescription == 'LGON' || eventTypeDescription == 'LGOF')) ~> filter1",
				"filter1 derive(Date = :CurrentDate,",
				"          customer = upper($Customer),",
				"          CurrentDate := toDate(EcEventTime),",
				"          NightShift := @(Name=\"Night\",",
				"          Start=toTimestamp((toString(toDate(EcEventTime)) + \" \" + \"00:00:00\"), \"yyyy-MM-dd HH:mm:ss\"),",
				"          End=toTimestamp((toString(toDate(EcEventTime)) + \" \" + \"07:59:59\"), \"yyyy-MM-dd HH:mm:ss\")),",
				"          MorningShift := @(Name=\"Morning\",",
				"          Start=toTimestamp((toString(toDate(EcEventTime)) + \" \" + \"08:00:00\"), \"yyyy-MM-dd HH:mm:ss\"),",
				"          End=toTimestamp((toString(toDate(EcEventTime)) + \" \" + \"15:59:59\"), \"yyyy-MM-dd HH:mm:ss\")),",
				"          EveningShift := @(Name=\"Evening\",",
				"          Start=toTimestamp((toString(toDate(EcEventTime)) + \" \" + \"16:00:00\"), \"yyyy-MM-dd HH:mm:ss\"),",
				"          End=toTimestamp((toString(toDate(EcEventTime)) + \" \" + \"23:59:59\"), \"yyyy-MM-dd HH:mm:ss\"))) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          ecEventGkey,",
				"          yardGkey,",
				"          YardID,",
				"          FcyID,",
				"          cheKind,",
				"          cheName = CHE_Name,",
				"          cheID,",
				"          type = eventType,",
				"          subType = eventSubType,",
				"          typeDescription = eventTypeDescription,",
				"          fromCheIdName,",
				"          ToCheIdName,",
				"          unitIdName = unit,",
				"          powName = pow,",
				"          poolName = pool,",
				"          workQueue,",
				"          travelDistance,",
				"          moveKind,",
				"          isTwin,",
				"          startDistance,",
				"          locSlot,",
				"          operatorName = operator,",
				"          customer,",
				"          EcEventTime,",
				"          Year,",
				"          Month,",
				"          Week,",
				"          Date",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"derivedColumn2 alterRow(upsertIf(true())) ~> alterRow1",
				"window2 window(over(cheID,",
				"          Date),",
				"     asc(EcEventTime, true),",
				"     asc(ecEventGkey, true),",
				"     typeDescription_next = lead(typeDescriptionGlobalNext),",
				"          typeDescription_prev = lag(typeDescriptionGlobalNext),",
				"          EcEventTime_next = lead(EcEventTime)) ~> window1",
				"window1 derive(LgonTime = iif(typeDescription=='LGON' && typeDescription_next=='LGOF', \r",
				"EcEventTime, \r",
				"iif((typeDescription=='LGOFF' && typeDescription_prev==\"\" && typeDescriptionGlobalPrev ==\"LGON\" && typeDescription_next=='LGON'), \r",
				":Day.Start, \r",
				"iif(typeDescription==\"LGON\" && typeDescription_next==\"\" && typeDescriptionGlobalNext==\"LGOF\" && typeDescription_prev=='LGOF',\r",
				"EcEventTime, \r",
				"toTimestamp(null()))\r",
				")\r",
				"),",
				"          LgOffTime = iif(typeDescription=='LGON' && typeDescription_next=='LGOF', \r",
				"EcEventTime_next, \r",
				"iif((typeDescription=='LGOFF' && typeDescription_prev==\"\" && typeDescriptionGlobalPrev ==\"LGON\" && typeDescription_next=='LGON'), \r",
				"EcEventTime, \r",
				"iif(typeDescription==\"LGON\" && typeDescription_next==\"\" && typeDescriptionGlobalNext==\"LGOF\" && typeDescription_prev=='LGOF',\r",
				":Day.End, \r",
				"toTimestamp(null()))\r",
				")\r",
				"),",
				"          lgoff_miss_flag = iif(typeDescription==\"LGON\" && typeDescriptionGlobalNext!=\"LGOF\", 1,0),",
				"          lgon_miss_flag = iif(typeDescription==\"LGOF\" && typeDescriptionGlobalPrev!=\"LGON\", 1,0),",
				"          Day := @(Start=toTimestamp((toString(toDate(EcEventTime)) + \" \" + \"00:00:00\"), \"yyyy-MM-dd HH:mm:ss\"),",
				"          End=toTimestamp((toString(toDate(EcEventTime)) + \" \" + \"23:59:59\"), \"yyyy-MM-dd HH:mm:ss\"))) ~> derivedColumn2",
				"ecevents aggregate(groupBy(ecEventGkey),",
				"     each(match(name!='ecEventGkey'), $$ = first($$))) ~> aggregate1",
				"moves aggregate(groupBy(mve_gkey),",
				"     each(match(name!='mve_gkey'), $$ = first($$))) ~> aggregate2",
				"aggregate2 filter(not(isNull(mve_gkey))) ~> filter3",
				"filter3 split(in([\"DLVR\",\"LOAD\",\"SHFT\"], Move_Kind) && Fetch_CHE_Kind==\"RTG\" && not(isNull(Fetch_CHE_Id)),",
				"     in([\"DSCH\",\"RECV\"], Move_Kind) && Put_CHE_Kind==\"RTG\"  && not(isNull(Put_CHE_Id)),",
				"     Move_Kind==\"YARD\",",
				"     disjoint: true) ~> split1@(LSD, RD, Y)",
				"split1@Y split((Fetch_CHE_Kind==\"RTG\" || Put_CHE_Kind==\"RTG\") && Fetch_CHE_Id==Put_CHE_Id && not(isNull(Put_CHE_Id)),",
				"     (Fetch_CHE_Kind==\"RTG\" || Put_CHE_Kind==\"RTG\") && Fetch_CHE_Id!=Put_CHE_Id && not(isNull(Fetch_CHE_Id)) && not(isNull(Put_CHE_Id)),",
				"     disjoint: true) ~> split2@(YE, YNE)",
				"split1@LSD select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          From_Position_Name,",
				"          To_Position_Name,",
				"          CHE_Operator_Id = Fetch_CHE_Operator_Id,",
				"          CHE_Id = Fetch_CHE_Id,",
				"          CHE_Kind = Fetch_CHE_Kind,",
				"          move_time = t_fetch,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"split1@RD select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          From_Position_Name,",
				"          To_Position_Name,",
				"          CHE_Operator_Id = Put_CHE_Operator_Id,",
				"          CHE_Id = Put_CHE_Id,",
				"          CHE_Kind = Put_CHE_Kind,",
				"          move_time = t_put,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"split2@YE select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          From_Position_Name,",
				"          To_Position_Name,",
				"          CHE_Operator_Id = Put_CHE_Operator_Id,",
				"          CHE_Id = Put_CHE_Id,",
				"          CHE_Kind = Put_CHE_Kind,",
				"          move_time = t_put,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4",
				"split2@YNE select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          From_Position_Name,",
				"          To_Position_Name,",
				"          CHE_Operator_Id = Put_CHE_Operator_Id,",
				"          CHE_Id = Put_CHE_Id,",
				"          CHE_Kind = Put_CHE_Kind,",
				"          move_time = t_put,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select6Put",
				"split2@YNE select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          From_Position_Name,",
				"          To_Position_Name,",
				"          CHE_Operator_Id = Fetch_CHE_Operator_Id,",
				"          CHE_Id = Fetch_CHE_Id,",
				"          CHE_Kind = Fetch_CHE_Kind,",
				"          move_time = t_fetch,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select5Fetch",
				"select5Fetch derive(Move_Primary_key = toString(Move_Primary_key) + \"-\" + toString(CHE_Kind) + \"-\" + toString(CHE_Id)) ~> derivedColumn4",
				"select6Put derive(Move_Primary_key = toString(Move_Primary_key) + \"-\" + toString(CHE_Kind) + \"-\" + toString(CHE_Id)) ~> derivedColumn5",
				"select3, select4, select2, derivedColumn4, derivedColumn5 union(byName: true)~> union1",
				"union1 aggregate(groupBy(Move_Primary_key),",
				"     each(match(name!='Move_Primary_key'), $$ = first($$))) ~> aggregate",
				"select6 alterRow(upsertIf(true())) ~> alterRow2",
				"aggregate, filter4 join(CHE_Kind==cheKind && toString(cheID)==toString(CHE_Id) && move_time>=LgonTime && move_time<=LgOffTime,",
				"     joinType:'cross',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     partitionBy('key',",
				"          0,",
				"          CHE_Id",
				"     ),",
				"     broadcast: 'right')~> join1",
				"derivedColumn7 alterRow(upsertIf(true())) ~> AlterRow3",
				"derivedColumn2 filter(!isNull(typeDescription) && !isNull(LgonTime) && !isNull(LgOffTime)) ~> filter4",
				"select5 aggregate(groupBy(CHE_Kind,",
				"          cheID,",
				"          cheName,",
				"          Year,",
				"          Month,",
				"          Week,",
				"          Date,",
				"          LgonTime,",
				"          LgOffTime),",
				"     Move_count = countDistinct(Move_Primary_key)) ~> aggregate3",
				"aggregate3 derive(Worktime_Seconds = (toLong(LgOffTime) - toLong(LgonTime))/1000) ~> derivedColumn7",
				"join1 select(mapColumn(",
				"          Move_Primary_key,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          From_Position_Name,",
				"          To_Position_Name,",
				"          CHE_Operator_Id,",
				"          CHE_Id,",
				"          CHE_Kind,",
				"          move_time,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year = aggregate@Year,",
				"          Month = aggregate@Month,",
				"          Week = aggregate@Week,",
				"          ecEventGkey,",
				"          yardGkey,",
				"          YardID,",
				"          FcyID,",
				"          cheKind,",
				"          cheName,",
				"          cheID,",
				"          type,",
				"          subType,",
				"          typeDescription = typeDescriptionGlobalNext,",
				"          fromCheIdName,",
				"          ToCheIdName,",
				"          unitIdName,",
				"          powName,",
				"          poolName,",
				"          workQueue,",
				"          travelDistance,",
				"          moveKind,",
				"          isTwin,",
				"          startDistance,",
				"          locSlot,",
				"          operatorName,",
				"          customer,",
				"          EcEventTime,",
				"          Year = select1@Year,",
				"          Month = select1@Month,",
				"          Week = select1@Week,",
				"          Date,",
				"          typeDescription_next,",
				"          typeDescription_prev,",
				"          EcEventTime_next,",
				"          LgonTime,",
				"          LgOffTime",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select5",
				"aggregate, filter4 join(CHE_Id == cheID",
				"     && CHE_Kind == cheKind",
				"     && move_time >= LgonTime",
				"     && move_time <= LgOffTime,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'right')~> join2",
				"join2 derive(is_move_window_matched = iif(isNull(ecEventGkey), 0, 1)) ~> derivedColumn8",
				"derivedColumn8 select(mapColumn(",
				"          Move_Primary_key,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          From_Position_Name,",
				"          To_Position_Name,",
				"          CHE_Operator_Id,",
				"          CHE_Id,",
				"          CHE_Kind,",
				"          move_time,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year = aggregate@Year,",
