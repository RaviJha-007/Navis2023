{
	"name": "rtg_productivity_apmt_salalah",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "linkedService1",
						"type": "LinkedServiceReference"
					},
					"name": "moves"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "linkedService1",
						"type": "LinkedServiceReference"
					},
					"name": "rtgmove"
				}
			],
			"transformations": [
				{
					"name": "aggregate2"
				},
				{
					"name": "filter3"
				},
				{
					"name": "split1"
				},
				{
					"name": "split2"
				},
				{
					"name": "select2"
				},
				{
					"name": "select3"
				},
				{
					"name": "select4"
				},
				{
					"name": "select6Put"
				},
				{
					"name": "select5Fetch"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "union1"
				},
				{
					"name": "aggregate"
				},
				{
					"name": "alterRow2"
				},
				{
					"name": "derivedColumn8"
				},
				{
					"name": "window1"
				},
				{
					"name": "derivedColumn9"
				},
				{
					"name": "derivedColumn10"
				},
				{
					"name": "window2"
				},
				{
					"name": "aggregate3"
				},
				{
					"name": "derivedColumn11"
				},
				{
					"name": "aggregate4"
				}
			],
			"scriptLines": [
				"parameters{",
				"     Customer as string ('apmt-salalah')",
				"}",
				"source(output(",
				"          mve_gkey as string,",
				"          Unit_Nbr as string,",
				"          Facility_Id as string,",
				"          Complex_Id as string,",
				"          Yard_Id as string,",
				"          Carrier_Visit_Key as string,",
				"          Event_Type_Id as string,",
				"          Move_Kind as string,",
				"          From_Location as string,",
				"          To_Location as string,",
				"          From_Position_Name as string,",
				"          To_Position_Name as string,",
				"          Carry_CHE_Operator_Id as string,",
				"          Fetch_CHE_Operator_Id as string,",
				"          Put_CHE_Operator_Id as string,",
				"          Fetch_CHE_Id as long,",
				"          Fetch_CHE_Kind as string,",
				"          Carry_CHE_Id as long,",
				"          Carry_CHE_Kind as string,",
				"          Put_CHE_Id as long,",
				"          Put_CHE_Kind as string,",
				"          QC_CHE_Id as long,",
				"          QC_CHE_Kind as string,",
				"          t_carry_complete as timestamp,",
				"          t_put as timestamp,",
				"          t_fetch as timestamp,",
				"          t_dispatch as timestamp,",
				"          t_discharge as timestamp,",
				"          t_carry_dispatch as timestamp,",
				"          t_carry_fetch_ready as timestamp,",
				"          t_carry_put_ready as timestamp,",
				"          dist_carry as string,",
				"          dist_start as string,",
				"          Twin_Fetch as string,",
				"          Twin_Carry as string,",
				"          Twin_Put as string,",
				"          Category_Id as string,",
				"          Freight_Kind_Id as string,",
				"          to_pos_gkey as string,",
				"          fm_pos_gkey as string,",
				"          Restow_Reason as string,",
				"          Container_Line_Id as string,",
				"          Container_Line_Role as string,",
				"          pow as string,",
				"          ufv_gkey as string,",
				"          Berth_Id as string,",
				"          Goods_And_Ctr_Wt_Kg as string,",
				"          active_ufv as string,",
				"          Requires_Power_Flag as string,",
				"          OOG_Flag as string,",
				"          Shipper_Id as string,",
				"          Consignee_Id as string,",
				"          Commodity_Id as string,",
				"          ATD as timestamp,",
				"          Rehandles as string,",
				"          ATA as timestamp,",
				"          Year as integer,",
				"          Month as integer,",
				"          Week as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'silver/moves') ~> moves",
				"moves aggregate(groupBy(mve_gkey),",
				"     each(match(name!='mve_gkey'), $$ = first($$))) ~> aggregate2",
				"aggregate2 filter(not(isNull(mve_gkey))) ~> filter3",
				"filter3 split(in([\"DLVR\",\"LOAD\",\"SHFT\"], Move_Kind) && Fetch_CHE_Kind==\"RTG\" && not(isNull(Fetch_CHE_Id)),",
				"     in([\"DSCH\",\"RECV\"], Move_Kind) && Put_CHE_Kind==\"RTG\"  && not(isNull(Put_CHE_Id)),",
				"     Move_Kind==\"YARD\",",
				"     disjoint: true) ~> split1@(LSD, RD, Y)",
				"split1@Y split((Fetch_CHE_Kind==\"RTG\" || Put_CHE_Kind==\"RTG\") && Fetch_CHE_Id==Put_CHE_Id && not(isNull(Put_CHE_Id)),",
				"     (Fetch_CHE_Kind==\"RTG\" || Put_CHE_Kind==\"RTG\") && Fetch_CHE_Id!=Put_CHE_Id && not(isNull(Fetch_CHE_Id)) && not(isNull(Put_CHE_Id)),",
				"     disjoint: true) ~> split2@(YE, YNE)",
				"split1@LSD select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          From_Position_Name,",
				"          To_Position_Name,",
				"          CHE_Operator_Id = Fetch_CHE_Operator_Id,",
				"          CHE_Id = Fetch_CHE_Id,",
				"          CHE_Kind = Fetch_CHE_Kind,",
				"          move_time = t_fetch,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"split1@RD select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          From_Position_Name,",
				"          To_Position_Name,",
				"          CHE_Operator_Id = Put_CHE_Operator_Id,",
				"          CHE_Id = Put_CHE_Id,",
				"          CHE_Kind = Put_CHE_Kind,",
				"          move_time = t_put,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"split2@YE select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          From_Position_Name,",
				"          To_Position_Name,",
				"          CHE_Operator_Id = Put_CHE_Operator_Id,",
				"          CHE_Id = Put_CHE_Id,",
				"          CHE_Kind = Put_CHE_Kind,",
				"          move_time = t_put,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4",
				"split2@YNE select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          From_Position_Name,",
				"          To_Position_Name,",
				"          CHE_Operator_Id = Put_CHE_Operator_Id,",
				"          CHE_Id = Put_CHE_Id,",
				"          CHE_Kind = Put_CHE_Kind,",
				"          move_time = t_put,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select6Put",
				"split2@YNE select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          From_Position_Name,",
				"          To_Position_Name,",
				"          CHE_Operator_Id = Fetch_CHE_Operator_Id,",
				"          CHE_Id = Fetch_CHE_Id,",
				"          CHE_Kind = Fetch_CHE_Kind,",
				"          move_time = t_fetch,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select5Fetch",
				"select5Fetch derive(Move_Primary_key = toString(Move_Primary_key) + \"-\" + toString(CHE_Kind) + \"-\" + toString(CHE_Id)) ~> derivedColumn4",
				"select6Put derive(Move_Primary_key = toString(Move_Primary_key) + \"-\" + toString(CHE_Kind) + \"-\" + toString(CHE_Id)) ~> derivedColumn5",
				"select3, select4, select2, derivedColumn4, derivedColumn5 union(byName: true)~> union1",
				"union1 aggregate(groupBy(Move_Primary_key),",
				"     each(match(name!='Move_Primary_key'), $$ = first($$))) ~> aggregate",
				"derivedColumn8 alterRow(upsertIf(true())) ~> alterRow2",
				"aggregate derive(move_date = toDate(move_time)) ~> derivedColumn8",
				"derivedColumn8 window(over(CHE_Id),",
				"     asc(move_time, true),",
				"     prev_move_time = lag(move_time,1)) ~> window1",
				"window1 derive(moves_gap_seconds = (toLong(move_time) - toLong(prev_move_time))/1000) ~> derivedColumn9",
				"derivedColumn9 derive(new_move_session_flag = iif(isNull(prev_move_time) || moves_gap_seconds > 10800,     1,     0 )) ~> derivedColumn10",
				"derivedColumn10 window(over(CHE_Id),",
				"     asc(move_time, true),",
				"     moves_session_id = sum(new_move_session_flag)) ~> window2",
				"window2 aggregate(groupBy(CHE_Id,",
				"          moves_session_id),",
				"     first_lift = min(move_time),",
				"          last_lift = max(move_time),",
				"          moves_count = countDistinct(Move_Primary_key)) ~> aggregate3",
				"aggregate3 derive(Worktime_Seconds = \r",
				"iif(moves_count == 1, toLong(3600), (toLong(last_lift) - toLong(first_lift))/1000),",
				"          move_date = toDate(first_lift)) ~> derivedColumn11",
				"derivedColumn11 aggregate(groupBy(move_date,",
				"          CHE_Id),",
				"     Total_Moves = sum(moves_count),",
				"          Total_Work_Seconds = sum(Worktime_Seconds)) ~> aggregate4",
				"alterRow2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'gold/rtg_moves',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: false,",
				"     updateable: false,",
				"     upsertable: true,",
				"     keys:['Move_Primary_key'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> rtgmove"
			]
		}
	}
}