{
	"name": "rtg_productivity_lane_apmt_salalah",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "linkedService1",
						"type": "LinkedServiceReference"
					},
					"name": "moves"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "linkedService1",
						"type": "LinkedServiceReference"
					},
					"name": "LaneProductivity"
				},
				{
					"linkedService": {
						"referenceName": "linkedService2",
						"type": "LinkedServiceReference"
					},
					"name": "LaneWorkhours"
				}
			],
			"transformations": [
				{
					"name": "aggregate2"
				},
				{
					"name": "filter3"
				},
				{
					"name": "split1"
				},
				{
					"name": "split2"
				},
				{
					"name": "select2"
				},
				{
					"name": "select3"
				},
				{
					"name": "select4"
				},
				{
					"name": "select6Put"
				},
				{
					"name": "select5Fetch"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "union1"
				},
				{
					"name": "aggregate"
				},
				{
					"name": "derivedColumn8"
				},
				{
					"name": "window1"
				},
				{
					"name": "derivedColumn9"
				},
				{
					"name": "derivedColumn10"
				},
				{
					"name": "derivedColumn11"
				},
				{
					"name": "aggregate4"
				},
				{
					"name": "alterRow3"
				},
				{
					"name": "filter6"
				},
				{
					"name": "Fetch"
				},
				{
					"name": "Put"
				},
				{
					"name": "alterRow4"
				},
				{
					"name": "select5"
				},
				{
					"name": "derivedColumn12"
				},
				{
					"name": "filter7"
				},
				{
					"name": "derivedColumn13"
				}
			],
			"scriptLines": [
				"parameters{",
				"     Customer as string ('apmt-salalah')",
				"}",
				"source(output(",
				"          mve_gkey as string,",
				"          Unit_Nbr as string,",
				"          Facility_Id as string,",
				"          Complex_Id as string,",
				"          Yard_Id as string,",
				"          Carrier_Visit_Key as string,",
				"          Event_Type_Id as string,",
				"          Move_Kind as string,",
				"          From_Location as string,",
				"          To_Location as string,",
				"          From_Position_Name as string,",
				"          To_Position_Name as string,",
				"          Carry_CHE_Operator_Id as string,",
				"          Fetch_CHE_Operator_Id as string,",
				"          Put_CHE_Operator_Id as string,",
				"          Fetch_CHE_Id as long,",
				"          Fetch_CHE_Kind as string,",
				"          Carry_CHE_Id as long,",
				"          Carry_CHE_Kind as string,",
				"          Put_CHE_Id as long,",
				"          Put_CHE_Kind as string,",
				"          QC_CHE_Id as long,",
				"          QC_CHE_Kind as string,",
				"          t_carry_complete as timestamp,",
				"          t_put as timestamp,",
				"          t_fetch as timestamp,",
				"          t_dispatch as timestamp,",
				"          t_discharge as timestamp,",
				"          t_carry_dispatch as timestamp,",
				"          t_carry_fetch_ready as timestamp,",
				"          t_carry_put_ready as timestamp,",
				"          dist_carry as string,",
				"          dist_start as string,",
				"          Twin_Fetch as string,",
				"          Twin_Carry as string,",
				"          Twin_Put as string,",
				"          Category_Id as string,",
				"          Freight_Kind_Id as string,",
				"          to_pos_gkey as string,",
				"          fm_pos_gkey as string,",
				"          Restow_Reason as string,",
				"          Container_Line_Id as string,",
				"          Container_Line_Role as string,",
				"          pow as string,",
				"          ufv_gkey as string,",
				"          Berth_Id as string,",
				"          Goods_And_Ctr_Wt_Kg as string,",
				"          active_ufv as string,",
				"          Requires_Power_Flag as string,",
				"          OOG_Flag as string,",
				"          Shipper_Id as string,",
				"          Consignee_Id as string,",
				"          Commodity_Id as string,",
				"          ATD as timestamp,",
				"          Rehandles as string,",
				"          ATA as timestamp,",
				"          Year as integer,",
				"          Month as integer,",
				"          Week as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'silver/moves') ~> moves",
				"moves aggregate(groupBy(mve_gkey),",
				"     each(match(name!='mve_gkey'), $$ = first($$))) ~> aggregate2",
				"aggregate2 filter(not(isNull(mve_gkey))) ~> filter3",
				"filter3 split(in([\"DLVR\",\"LOAD\"], Move_Kind) && Fetch_CHE_Kind==\"RTG\" && not(isNull(Fetch_CHE_Id)),",
				"     in([\"DSCH\",\"RECV\"], Move_Kind) && Put_CHE_Kind==\"RTG\"  && not(isNull(Put_CHE_Id)),",
				"     in([\"YARD\",\"SHFT\"], Move_Kind),",
				"     disjoint: true) ~> split1@(LD, RD, YS)",
				"split1@YS split((Fetch_CHE_Kind==\"RTG\" || Put_CHE_Kind==\"RTG\") && Fetch_CHE_Id==Put_CHE_Id && not(isNull(Put_CHE_Id)) && not(isNull(Fetch_CHE_Id)),",
				"     (Fetch_CHE_Kind==\"RTG\" || Put_CHE_Kind==\"RTG\") && (not(equals(Put_CHE_Id, Fetch_CHE_Id)) || isNull(Fetch_CHE_Id) || isNull(Put_CHE_Id)),",
				"     disjoint: true) ~> split2@(YSE, YSNE)",
				"split1@LD select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          Position_Name = From_Position_Name,",
				"          CHE_Operator_Id = Fetch_CHE_Operator_Id,",
				"          CHE_Id = Fetch_CHE_Id,",
				"          CHE_Kind = Fetch_CHE_Kind,",
				"          move_time = t_fetch,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"split1@RD select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          Position_Name = To_Position_Name,",
				"          CHE_Operator_Id = Put_CHE_Operator_Id,",
				"          CHE_Id = Put_CHE_Id,",
				"          CHE_Kind = Put_CHE_Kind,",
				"          move_time = t_put,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"split2@YSE select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          Position_Name = To_Position_Name,",
				"          CHE_Operator_Id = Put_CHE_Operator_Id,",
				"          CHE_Id = Put_CHE_Id,",
				"          CHE_Kind = Put_CHE_Kind,",
				"          move_time = t_put,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4",
				"Put select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          Position_Name = To_Position_Name,",
				"          CHE_Operator_Id = Put_CHE_Operator_Id,",
				"          CHE_Id = Put_CHE_Id,",
				"          CHE_Kind = Put_CHE_Kind,",
				"          move_time = t_put,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select6Put",
				"Fetch select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Complex_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          Position_Name = From_Position_Name,",
				"          CHE_Operator_Id = Fetch_CHE_Operator_Id,",
				"          CHE_Id = Fetch_CHE_Id,",
				"          CHE_Kind = Fetch_CHE_Kind,",
				"          move_time = t_fetch,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select5Fetch",
				"select5Fetch derive(Move_Primary_key = toString(Move_Primary_key) + \"-\" + toString(CHE_Kind) + \"-\" + \"FETCH\" + \"-\"+ toString(CHE_Id)) ~> derivedColumn4",
				"select6Put derive(Move_Primary_key = toString(Move_Primary_key) + \"-\" + toString(CHE_Kind) + \"-\" + \"PUT\" + \"-\"+ toString(CHE_Id)) ~> derivedColumn5",
				"select3, select4, select2, derivedColumn4, derivedColumn5 union(byName: true)~> union1",
				"union1 aggregate(groupBy(Move_Primary_key),",
				"     each(match(name!='Move_Primary_key'), $$ = first($$))) ~> aggregate",
				"filter6 derive(move_date = toDate(move_time),",
				"          Block_Id = :position,",
				"          Lane_Id = upper(right(:position,1)),",
				"          Lane_Number = left(:position,2),",
				"          position := left(split(Position_Name, \"-\")[3], 3)) ~> derivedColumn8",
				"derivedColumn13 window(over(CHE_Id),",
				"     asc(move_time, true),",
				"     prev_move_time = lag(move_time,1),",
				"          prev_operator_id = lag(CHE_Operator_Id,1)) ~> window1",
				"window1 derive(moves_gap_seconds = (toLong(move_time) - toLong(prev_move_time))/1000) ~> derivedColumn9",
				"derivedColumn9 derive(new_move_session_flag = iif(isNull(prev_move_time) || moves_gap_seconds > 10800  || CHE_Operator_Id != prev_operator_id,     1,     0 )) ~> derivedColumn10",
				"derivedColumn10 derive(Worktime_Seconds = iif(new_move_session_flag==1, toLong(0), moves_gap_seconds)) ~> derivedColumn11",
				"derivedColumn11 aggregate(groupBy(Year,",
				"          Month,",
				"          Week,",
				"          move_date,",
				"          CHE_Kind,",
				"          CHE_Id,",
				"          Lane_Name),",
				"     Total_Moves = countDistinct(Move_Primary_key),",
				"          Total_Work_Seconds = sum(Worktime_Seconds)) ~> aggregate4",
				"aggregate4 alterRow(upsertIf(true())) ~> alterRow3",
				"aggregate filter(CHE_Kind==\"RTG\" && not(isNull(CHE_Id)) && not(isNull(CHE_Kind)) && not(isNull(move_time))) ~> filter6",
				"split2@YSNE derive(t_fetch = iif((Move_Kind=='YARD' && not(isNull(Fetch_CHE_Id)) && Fetch_CHE_Kind==\"RTG\" && isNull(t_fetch)), t_dispatch, t_fetch)) ~> Fetch",
				"split2@YSNE derive(t_put = iif((Move_Kind=='YARD' && not(isNull(Put_CHE_Id)) && Put_CHE_Kind==\"RTG\" && isNull(t_put)), t_carry_complete, t_put)) ~> Put",
				"select5 alterRow(upsertIf(true())) ~> alterRow4",
				"derivedColumn11 select(mapColumn(",
				"          Move_Primary_key,",
				"          Unit_Nbr,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          CHE_Id,",
				"          CHE_Kind,",
				"          CHE_Operator_Id,",
				"          prev_operator_id,",
				"          move_time,",
				"          prev_move_time,",
				"          Year,",
				"          Month,",
				"          Week,",
				"          move_date,",
				"          moves_gap_seconds,",
				"          new_move_session_flag,",
				"          Worktime_Seconds,",
				"          Block_Type,",
				"          Lane_Id,",
				"          Lane_Name",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select5",
				"filter7 derive(Block_Type = iif(in(:{7WideBlocks},Block_Id), \"7 Wide\", iif(in(:RSTBlocks,Block_Id), \"RST\", \"6 Wide\")),",
				"          {7WideBlocks} := [\"01H\",\"02H\",\"03H\",\"01G\",\"02G\",\"03G\",\"01E\",\"02E\",\"03E\",\"04E\",\"01C\",\"02C\",\"03C\",\"04C\"],",
				"          RSTBlocks := [\"03S\",\"03R\"]) ~> derivedColumn12",
				"derivedColumn8 filter(((Lane_Id >='A' && Lane_Id<='H') && in([\"01\",\"02\",\"03\",\"05\",\"06\",\"Z6\"], Lane_Number)) || in([\"03S\",\"03R\",\"04A\",\"04B\",\"04C\",\"04D\",\"04E\",\"04F\"],Block_Id)) ~> filter7",
				"derivedColumn12 derive(Lane_Name = iif(Block_Type==\"RST\", Block_Type, Lane_Id + \": \"+ Block_Type)) ~> derivedColumn13",
				"alterRow3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'gold/rtg_lane_productivity',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: false,",
				"     updateable: false,",
				"     upsertable: true,",
				"     keys:['move_date','CHE_Id'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> LaneProductivity",
				"alterRow4 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'gold/rtg_lane_workhours',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: false,",
				"     updateable: false,",
				"     upsertable: true,",
				"     keys:['Move_Primary_key'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> LaneWorkhours"
			]
		}
	}
}