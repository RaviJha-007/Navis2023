{
	"name": "stack_confirmity_PNG",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "linkedService2",
						"type": "LinkedServiceReference"
					},
					"name": "StackConfirmity"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "linkedService2",
						"type": "LinkedServiceReference"
					},
					"name": "StackConformity"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "aggregate1"
				},
				{
					"name": "join1"
				},
				{
					"name": "sort1"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "select2"
				},
				{
					"name": "select3"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "filter2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "aggregate3"
				},
				{
					"name": "sort2"
				},
				{
					"name": "join2"
				},
				{
					"name": "select4"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "filter3"
				}
			],
			"scriptLines": [
				"source(output(",
				"          {Equipment ID} as string,",
				"          Class as string,",
				"          Block as string,",
				"          {Current Position} as string,",
				"          {Planned Position} as string,",
				"          {Yard Row} as string,",
				"          {Yard Stack} as string,",
				"          {Outbound Carrier} as string,",
				"          POD as string,",
				"          Cls as short,",
				"          {Wgt-MTn} as double,",
				"          Sts as string,",
				"          {Cat.Qual} as string,",
				"          Stw1 as string,",
				"          Cat as string",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     inferDriftedColumnTypes: true,",
				"     ignoreNoFilesFound: true,",
				"     moveFiles: ['/bronze/stackconformity/load','bronze/stackconformity/archive'],",
				"     rowUrlColumn: 'FileDate',",
				"     format: 'delimited',",
				"     fileSystem: 'png',",
				"     folderPath: 'bronze/stackconformity/load',",
				"     columnDelimiter: '\\t',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '',",
				"     columnNamesAsHeader: true) ~> StackConfirmity",
				"select3 derive(Pos_WO_Tier = {Yard Stack},",
				"          Date = :created_date,",
				"          Week = iif(dayOfWeek(:created_date) == 1,  weekOfYear(:created_date) + 1, weekOfYear(:created_date)),",
				"          Tier = iif(not(isNull({Yard Stack})), :current_tier,\"\"),",
				"          StackingFactor = case(\r",
				"    Cat == 'EXPORT' || Cat == 'TRANSSHIP',\r",
				"    concat({Outbound Carrier},\"/\",POD,\"/\",toString(Cls),\"/\",Sts),\r",
				"\r",
				"    Cat == 'IMPORT',\r",
				"    {Outbound Carrier},\r",
				"\r",
				"    Cat == 'STORAGE',\r",
				"    concat({Outbound Carrier},\"/\",Sts),\r",
				"    \r",
				"    toString(null())\r",
				"),",
				"          created_date := toDate(split(split(FileDate, \".\")[1],\"/\")[5], 'yyyyMMdd'),",
				"          current_tier := right({Current Position}, 1)) ~> derivedColumn1",
				"filter3 aggregate(groupBy(Date,",
				"          Pos_WO_Tier),",
				"     Stack_Distinct = countDistinct(StackingFactor)\r",
				",",
				"          minTier = min(Tier),",
				"          maxWeight = max({Wgt-MTn}),",
				"          minWeight = min({Wgt-MTn})) ~> aggregate1",
				"filter3, derivedColumn2 join(derivedColumn1@Date == aggregate1@Date",
				"     && derivedColumn1@Pos_WO_Tier == aggregate1@Pos_WO_Tier,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"derivedColumn4 sort(asc(Date, true),",
				"     asc({Equipment ID}, true),",
				"     asc(Tier, true)) ~> sort1",
				"select2 alterRow(insertIf(true())) ~> alterRow1",
				"derivedColumn5 select(mapColumn(",
				"          each(match(true()),",
				"               regexReplace($$,' ','_') = $$)",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"StackConfirmity select(mapColumn(",
				"          {Equipment ID},",
				"          Class,",
				"          Block,",
				"          {Current Position},",
				"          {Planned Position},",
				"          {Yard Row},",
				"          {Yard Stack},",
				"          {Outbound Carrier},",
				"          POD,",
				"          Cls,",
				"          {Wgt-MTn},",
				"          Sts,",
				"          Qual = {Cat.Qual},",
				"          Stw1,",
				"          Cat,",
				"          FileDate",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"aggregate1 derive(Stack_Conformity = iif(Stack_Distinct>1 || isNull(Pos_WO_Tier) || Pos_WO_Tier==\"\"  , \"Mix\", \"Pure\")) ~> derivedColumn2",
				"join1 filter(Tier==minTier) ~> filter2",
				"aggregate3 derive(Weight_Conformity = iif((maxWeight>=:maxLimit || minWeight<=:minLimit), \"Mix\", \"Pure\"),",
				"          MaxWeightLimit = :maxLimit + 1000,",
				"          MinWeightLimit = :minLimit,",
				"          maxLimit := 1.15*refWeight,",
				"          minLimit := refWeight*0.85) ~> derivedColumn3",
				"sort2 aggregate(groupBy(derivedColumn1@Date,",
				"          derivedColumn1@Pos_WO_Tier,",
				"          minTier,",
				"          maxWeight,",
				"          minWeight),",
				"     refWeight = first({Wgt-MTn}, true())) ~> aggregate3",
				"filter2 sort(asc(aggregate1@Date, true),",
				"     asc(aggregate1@Pos_WO_Tier, true),",
				"     asc(Tier, true),",
				"     partitionLevel: true) ~> sort2",
				"join1, derivedColumn3 join(aggregate1@Date == aggregate3@Date",
				"     && aggregate1@Pos_WO_Tier == aggregate3@Pos_WO_Tier",
				"     && aggregate1@minTier == aggregate3@minTier",
				"     && aggregate1@maxWeight == aggregate3@maxWeight",
				"     && aggregate1@minWeight == aggregate3@minWeight,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"join2 select(mapColumn(",
				"          {Equipment ID},",
				"          Class,",
				"          Block,",
				"          {Current Position},",
				"          {Planned Position},",
				"          {Yard Row},",
				"          {Yard Stack},",
				"          {Outbound Carrier},",
				"          POD,",
				"          Cls,",
				"          {Wgt-MTn},",
				"          Sts,",
				"          Qual,",
				"          Stw1,",
				"          Cat,",
				"          FileDate,",
				"          Pos_WO_Tier = derivedColumn1@Pos_WO_Tier,",
				"          Date = derivedColumn1@Date,",
				"          Week,",
				"          Tier,",
				"          StackingFactor,",
				"          Date = aggregate1@Date,",
				"          Pos_WO_Tier = aggregate1@Pos_WO_Tier,",
				"          Stack_Distinct,",
				"          minTier = aggregate1@minTier,",
				"          maxWeight = aggregate1@maxWeight,",
				"          minWeight = aggregate1@minWeight,",
				"          Stack_Conformity,",
				"          Date = aggregate3@Date,",
				"          Pos_WO_Tier = aggregate3@Pos_WO_Tier,",
				"          minTier = aggregate3@minTier,",
				"          maxWeight = aggregate3@maxWeight,",
				"          minWeight = aggregate3@minWeight,",
				"          refWeight,",
				"          Weight_Conformity,",
				"          MaxWeightLimit,",
				"          MinWeightLimit",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4",
				"select4 derive(Weight_Conformity = iif(isNull(minTier) || Tier==\"\" , \"N/A\", Weight_Conformity),",
				"          Stack_Conformity = iif(isNull(minTier) || Tier==\"\" || StackingFactor==\"\", \"N/A\", Stack_Conformity)) ~> derivedColumn4",
				"sort1 derive(Conformity = iif(isInteger(Tier), \r",
				"iif((Weight_Conformity==\"Pure\" && Stack_Conformity==\"Pure\"), \"Pure\", \r",
				"iif((Weight_Conformity==\"Mix\" && Stack_Conformity==\"Pure\"), \"Pure Stack, Mixed Weight\",\r",
				"iif((Weight_Conformity==\"Pure\" && Stack_Conformity==\"Mix\"), \"Mixed Stack, Pure Weight\", \r",
				"iif((Weight_Conformity==\"Mix\" && Stack_Conformity==\"Mix\"), \"Mixed Stack, Mixed Weight\", \"N/A\")))),\"N/A\"),",
				"          valid_tier_array := [\"1\",\"2\",\"3\",\"4\"]) ~> derivedColumn5",
				"derivedColumn1 filter(isDate(toString(Date)) && not(isNull({Equipment ID})) && {Equipment ID} != '' && Pos_WO_Tier!=\"\" && Tier!=\"\") ~> filter3",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: 'png',",
				"     folderPath: 'gold/stack_confirmity',",
				"     mergeSchema: true,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: true,",
				"     updateable: false,",
				"     upsertable: false,",
				"     umask: 0777,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> StackConformity"
			]
		}
	}
}