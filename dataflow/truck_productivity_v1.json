{
	"name": "truck_productivity_v1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "linkedService2",
						"type": "LinkedServiceReference"
					},
					"name": "ecevents"
				},
				{
					"linkedService": {
						"referenceName": "linkedService1",
						"type": "LinkedServiceReference"
					},
					"name": "moves"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "linkedService2",
						"type": "LinkedServiceReference"
					},
					"name": "itvecevents"
				},
				{
					"linkedService": {
						"referenceName": "linkedService1",
						"type": "LinkedServiceReference"
					},
					"name": "itvmoves"
				},
				{
					"linkedService": {
						"referenceName": "linkedService1",
						"type": "LinkedServiceReference"
					},
					"name": "itvprod"
				},
				{
					"linkedService": {
						"referenceName": "linkedService1",
						"type": "LinkedServiceReference"
					},
					"name": "ProvisionalItvProd"
				}
			],
			"transformations": [
				{
					"name": "filter1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "window1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "aggregate1"
				},
				{
					"name": "aggregate2"
				},
				{
					"name": "filter3"
				},
				{
					"name": "select2"
				},
				{
					"name": "alterRow2"
				},
				{
					"name": "join1"
				},
				{
					"name": "AlterRow3"
				},
				{
					"name": "filter4"
				},
				{
					"name": "aggregate3"
				},
				{
					"name": "derivedColumn9"
				},
				{
					"name": "derivedColumn10"
				},
				{
					"name": "select3"
				},
				{
					"name": "window2"
				},
				{
					"name": "derivedColumn11"
				},
				{
					"name": "aggregate4"
				},
				{
					"name": "derivedColumn12"
				},
				{
					"name": "aggregate5"
				},
				{
					"name": "lookup1"
				},
				{
					"name": "alterRow4"
				}
			],
			"scriptLines": [
				"parameters{",
				"     Customer as string ('apmt-salalah')",
				"}",
				"source(output(",
				"          ecEventGkey as long,",
				"          yardGkey as string,",
				"          YardID as string,",
				"          FcyID as string,",
				"          cheKind as string,",
				"          CHE_Name as string,",
				"          eventType as short,",
				"          eventSubType as short,",
				"          eventTypeDescription as string,",
				"          fromCheIdName as string,",
				"          ToCheIdName as string,",
				"          unit as string,",
				"          pow as string,",
				"          pool as string,",
				"          workQueue as string,",
				"          travelDistance as short,",
				"          moveKind as string,",
				"          isTwin as boolean,",
				"          startDistance as short,",
				"          workAssignment as double,",
				"          unitRef as string,",
				"          tran_ID as string,",
				"          locType as string,",
				"          locID as string,",
				"          locSlot as string,",
				"          opsPosID as string,",
				"          unladenLoctype as string,",
				"          unladenLocID as string,",
				"          unladenLocSlot as string,",
				"          ladenLoctype as string,",
				"          ladenLocID as string,",
				"          laden_LocSlot as string,",
				"          EcEventTime as timestamp,",
				"          cheID as long,",
				"          Year as integer,",
				"          Month as integer,",
				"          Week as integer,",
				"          OPERATOR_ID as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'silver/ecevents') ~> ecevents",
				"source(output(",
				"          mve_gkey as long,",
				"          Unit_Nbr as string,",
				"          Facility_Id as string,",
				"          Yard_Id as string,",
				"          Carrier_Visit_Key as long,",
				"          Event_Type_Id as string,",
				"          Move_Kind as string,",
				"          From_Location as string,",
				"          To_Location as string,",
				"          From_Position_Name as string,",
				"          To_Position_Name as string,",
				"          Carry_CHE_Operator_Id as string,",
				"          Fetch_CHE_Operator_Id as string,",
				"          Put_CHE_Operator_Id as string,",
				"          Fetch_CHE_Id as long,",
				"          Fetch_CHE_Kind as string,",
				"          Carry_CHE_Id as long,",
				"          Carry_CHE_Kind as string,",
				"          Put_CHE_Id as long,",
				"          Put_CHE_Kind as string,",
				"          QC_CHE_Id as long,",
				"          QC_CHE_Kind as string,",
				"          t_carry_complete as timestamp,",
				"          t_put as timestamp,",
				"          t_fetch as timestamp,",
				"          t_dispatch as timestamp,",
				"          t_discharge as timestamp,",
				"          t_carry_dispatch as timestamp,",
				"          t_carry_fetch_ready as timestamp,",
				"          t_carry_put_ready as timestamp,",
				"          dist_carry as integer,",
				"          dist_start as integer,",
				"          Twin_Fetch as boolean,",
				"          Twin_Carry as boolean,",
				"          Twin_Put as boolean,",
				"          Category_Id as string,",
				"          Freight_Kind_Id as string,",
				"          Restow_Reason as string,",
				"          POW as string,",
				"          ufv_gkey as long,",
				"          Goods_And_Ctr_Wt_Kg as integer,",
				"          Requires_Power_Flag as boolean,",
				"          OOG_Flag as boolean,",
				"          ATA as timestamp,",
				"          ATD as timestamp,",
				"          Rehandles as short,",
				"          Year as integer,",
				"          Month as integer,",
				"          Week as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: true,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'silver/moves') ~> moves",
				"aggregate1 filter(not(isNull(ecEventGkey)) && cheKind == 'ITV' && (eventTypeDescription == 'LGON' || eventTypeDescription == 'LGOF')) ~> filter1",
				"filter1 derive(Date = :CurrentDate,",
				"          customer = upper($Customer),",
				"          CurrentDate := toDate(EcEventTime),",
				"          NightShift := @(Name=\"Night\",",
				"          Start=toTimestamp((toString(toDate(EcEventTime)) + \" \" + \"00:00:00\"), \"yyyy-MM-dd HH:mm:ss\"),",
				"          End=toTimestamp((toString(toDate(EcEventTime)) + \" \" + \"07:59:59\"), \"yyyy-MM-dd HH:mm:ss\")),",
				"          MorningShift := @(Name=\"Morning\",",
				"          Start=toTimestamp((toString(toDate(EcEventTime)) + \" \" + \"08:00:00\"), \"yyyy-MM-dd HH:mm:ss\"),",
				"          End=toTimestamp((toString(toDate(EcEventTime)) + \" \" + \"15:59:59\"), \"yyyy-MM-dd HH:mm:ss\")),",
				"          EveningShift := @(Name=\"Evening\",",
				"          Start=toTimestamp((toString(toDate(EcEventTime)) + \" \" + \"16:00:00\"), \"yyyy-MM-dd HH:mm:ss\"),",
				"          End=toTimestamp((toString(toDate(EcEventTime)) + \" \" + \"23:59:59\"), \"yyyy-MM-dd HH:mm:ss\"))) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          ecEventGkey,",
				"          yardGkey,",
				"          YardID,",
				"          FcyID,",
				"          cheKind,",
				"          cheName = CHE_Name,",
				"          cheID,",
				"          type = eventType,",
				"          subType = eventSubType,",
				"          typeDescription = eventTypeDescription,",
				"          fromCheIdName,",
				"          ToCheIdName,",
				"          unitIdName = unit,",
				"          powName = pow,",
				"          poolName = pool,",
				"          workQueue,",
				"          travelDistance,",
				"          moveKind,",
				"          isTwin,",
				"          startDistance,",
				"          locSlot,",
				"          operatorName = OPERATOR_ID,",
				"          customer,",
				"          EcEventTime,",
				"          Year,",
				"          Month,",
				"          Week,",
				"          Date",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"derivedColumn2 alterRow(upsertIf(true())) ~> alterRow1",
				"window2 window(over(cheID,",
				"          Date),",
				"     asc(EcEventTime, true),",
				"     asc(ecEventGkey, true),",
				"     typeDescription_next = lead(typeDescription,1),",
				"          typeDescription_prev = lag(typeDescription,1),",
				"          EcEventTime_next = lead(EcEventTime,1)) ~> window1",
				"window1 derive(LgonTime = iif(typeDescription=='LGON' && typeDescription_next=='LGOF', \r",
				"EcEventTime, \r",
				"iif(typeDescription=='LGOF' && (typeDescription_prev==\"\" || isNull(typeDescription_prev)) && typeDescriptionGlobalPrev ==\"LGON\" && typeDescription_next=='LGON', \r",
				":Day.Start, \r",
				"iif(typeDescription==\"LGON\" && (typeDescription_next==\"\" || isNull(typeDescription_next)) && typeDescriptionGlobalNext==\"LGOF\" && typeDescription_prev=='LGOF',\r",
				"EcEventTime, \r",
				"toTimestamp(null()))\r",
				")\r",
				"),",
				"          LgOffTime = iif(typeDescription=='LGON' && typeDescription_next=='LGOF', \r",
				"EcEventTime_next, \r",
				"iif(typeDescription=='LGOF' && (typeDescription_prev==\"\" || isNull(typeDescription_prev)) && typeDescriptionGlobalPrev ==\"LGON\" && typeDescription_next=='LGON', \r",
				"EcEventTime, \r",
				"iif(typeDescription==\"LGON\" && (typeDescription_next==\"\" || isNull(typeDescription_next)) && typeDescriptionGlobalNext==\"LGOF\" && typeDescription_prev=='LGOF',\r",
				":Day.End, \r",
				"toTimestamp(null()))\r",
				")\r",
				"),",
				"          lgoff_miss_flag = iif(typeDescription==\"LGON\" && typeDescriptionGlobalNext!=\"LGOF\", 1,0),",
				"          lgon_miss_flag = iif(typeDescription==\"LGOF\" && typeDescriptionGlobalPrev!=\"LGON\", 1,0),",
				"          Day := @(Start=toTimestamp((toString(toDate(EcEventTime)) + \" \" + \"00:00:00\"), \"yyyy-MM-dd HH:mm:ss\"),",
				"          End=toTimestamp((toString(toDate(EcEventTime)) + \" \" + \"23:59:59\"), \"yyyy-MM-dd HH:mm:ss\"))) ~> derivedColumn2",
				"ecevents aggregate(groupBy(ecEventGkey),",
				"     each(match(name!='ecEventGkey'), $$ = first($$))) ~> aggregate1",
				"moves aggregate(groupBy(mve_gkey),",
				"     each(match(name!='mve_gkey'), $$ = first($$))) ~> aggregate2",
				"aggregate2 filter(not(isNull(mve_gkey)) && in([\"DLVR\",\"LOAD\",\"SHFT\",\"DSCH\",\"RECV\", \"YARD\"], Move_Kind) && Carry_CHE_Kind==\"ITV\" && not(isNull(Carry_CHE_Id))) ~> filter3",
				"derivedColumn9 select(mapColumn(",
				"          Move_Primary_key = mve_gkey,",
				"          Unit_Nbr,",
				"          Facility_Id,",
				"          Yard_Id,",
				"          Carrier_Visit_Key,",
				"          Event_Type_Id,",
				"          Move_Kind,",
				"          From_Location,",
				"          To_Location,",
				"          From_Position_Name,",
				"          To_Position_Name,",
				"          CHE_Operator_Id = Carry_CHE_Operator_Id,",
				"          CHE_Id = Carry_CHE_Id,",
				"          CHE_Kind = Carry_CHE_Kind,",
				"          move_time = t_carry_complete,",
				"          dist_carry,",
				"          dist_start,",
				"          Category_Id,",
				"          Freight_Kind_Id,",
				"          pow = POW,",
				"          ufv_gkey,",
				"          Year,",
				"          Month,",
				"          Week,",
				"          valid_twin_flag",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select2 alterRow(upsertIf(true())) ~> alterRow2",
				"select2, filter4 join(lower(CHE_Kind)==lower(cheKind) && toString(cheID)==toString(CHE_Id) && move_time>=LgonTime && move_time<=LgOffTime,",
				"     joinType:'cross',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     partitionBy('key',",
				"          0,",
				"          CHE_Id",
				"     ),",
				"     broadcast: 'right')~> join1",
				"derivedColumn10 alterRow(upsertIf(true())) ~> AlterRow3",
				"derivedColumn2 filter(!isNull(typeDescription) && !isNull(LgonTime) && !isNull(LgOffTime)) ~> filter4",
				"select3 aggregate(groupBy(CHE_Kind,",
				"          cheID,",
				"          cheName,",
				"          Year,",
				"          Month,",
				"          Week,",
				"          Date,",
				"          LgonTime,",
				"          LgOffTime),",
				"     Move_count = countDistinct(Move_Primary_key),",
				"          Twin_count = sum(valid_twin_flag)) ~> aggregate3",
				"filter3 derive(valid_twin_flag = iif(Twin_Carry==true(),1,0)) ~> derivedColumn9",
				"aggregate3 derive(Worktime_seconds = (toLong(LgOffTime) - toLong(LgonTime))/1000) ~> derivedColumn10",
				"join1 select(mapColumn(",
				"          each(match(/* All input columns */true()),",
				"               /* Input name */$$ = $$)",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"select1 window(over(cheKind,",
				"          cheID),",
				"     asc(EcEventTime, true),",
				"     asc(ecEventGkey, true),",
				"     typeDescriptionGlobalNext = lead(typeDescription,1),",
				"          typeDescriptionGlobalPrev = lag(typeDescription,1)) ~> window2",
				"filter4 derive(WorkTime_seconds = (toLong(LgOffTime) - toLong(LgonTime))/1000) ~> derivedColumn11",
				"derivedColumn11 aggregate(groupBy(Date,",
				"          cheKind,",
				"          cheID,",
				"          cheName),",
				"     WorkTime_seconds_prov = sum(WorkTime_seconds)) ~> aggregate4",
				"select2 derive(move_date = toDate(move_time)) ~> derivedColumn12",
				"derivedColumn12 aggregate(groupBy(move_date,",
				"          CHE_Kind,",
				"          CHE_Id),",
				"     Move_count_prov = countDistinct(Move_Primary_key),",
				"          Twin_count_prov = sum(valid_twin_flag)) ~> aggregate5",
				"aggregate4, aggregate5 lookup(Date == move_date",
				"     && lower(toString(cheKind)) == lower(toString(CHE_Kind))",
				"     && lower(toString(cheID)) == lower(toString(CHE_Id)),",
				"     multiple: true,",
				"     broadcast: 'auto')~> lookup1",
				"lookup1 alterRow(upsertIf(true())) ~> alterRow4",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'gold/itv_ecevents',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: false,",
				"     updateable: false,",
				"     upsertable: true,",
				"     keys:['ecEventGkey'],",
				"     umask: 0777,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> itvecevents",
				"alterRow2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'gold/itv_moves',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: false,",
				"     updateable: false,",
				"     upsertable: true,",
				"     keys:['Move_Primary_key'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> itvmoves",
				"AlterRow3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'gold/itv_productivity',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: false,",
				"     updateable: false,",
				"     upsertable: true,",
				"     keys:['Year','Month','Week','Date','cheID','cheName'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> itvprod",
				"alterRow4 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: ($Customer),",
				"     folderPath: 'gold/itv_productivity_prov',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: true,",
				"     updateable: false,",
				"     upsertable: true,",
				"     keys:['Date','cheKind','cheID','cheName'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> ProvisionalItvProd"
			]
		}
	}
}