{
	"name": "AzureBlobNavisPowerBi",
	"properties": {
		"linkedServiceName": {
			"referenceName": "AzureBlobStorage1",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"containerName": {
				"type": "string",
				"defaultValue": "teagtl"
			},
			"fileType": {
				"type": "string",
				"defaultValue": "moves"
			}
		},
		"annotations": [],
		"type": "Binary",
		"typeProperties": {
			"location": {
				"type": "AzureBlobStorageLocation",
				"folderPath": "@concat('bronze/',dataset().fileType,'/load')",
				"container": {
					"value": "@dataset().containerName",
					"type": "Expression"
				}
			}
		}
	}
}