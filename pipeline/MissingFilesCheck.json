{
	"name": "MissingFilesCheck",
	"properties": {
		"activities": [
			{
				"name": "GM_CheckFiles",
				"type": "GetMetadata",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataset": {
						"referenceName": "AzureBlobNavisPowerBi",
						"type": "DatasetReference",
						"parameters": {
							"containerName": {
								"value": "@pipeline().parameters.containerName",
								"type": "Expression"
							},
							"fileType": {
								"value": "@pipeline().parameters.fileType",
								"type": "Expression"
							}
						}
					},
					"fieldList": [
						"childItems"
					],
					"storeSettings": {
						"type": "AzureBlobStorageReadSettings",
						"modifiedDatetimeStart": {
							"value": "@getPastTime(2,'Day')",
							"type": "Expression"
						},
						"modifiedDatetimeEnd": {
							"value": "@utcNow()",
							"type": "Expression"
						},
						"enablePartitionDiscovery": false
					},
					"formatSettings": {
						"type": "BinaryReadSettings"
					}
				}
			}
		],
		"parameters": {
			"containerName": {
				"type": "string",
				"defaultValue": "teagtl"
			},
			"fileType": {
				"type": "string",
				"defaultValue": "moves"
			}
		},
		"annotations": []
	}
}