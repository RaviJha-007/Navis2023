{
	"name": "WI_01_Rehandles",
	"properties": {
		"description": "This pipeline runs the bronze to Silver layer data loading and Rehandles Logic",
		"activities": [
			{
				"name": "WI01",
				"type": "SynapseNotebook",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"typeProperties": {
