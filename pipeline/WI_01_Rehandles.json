						"referenceName": "WI_01_Notebook",
						"type": "NotebookReference"
					},
					"parameters": {
						"client_id": {
							"value": {
								"value": "@pipeline().parameters.client_id",
								"type": "Expression"
							},
							"type": "string"
						},
						"file_system": {
							"value": {
								"value": "@pipeline().parameters.file_system",
								"type": "Expression"
							},
							"type": "string"
						}
					},
					"snapshot": true,
